# ===========================================================================
# Generated portal artifacts — DO NOT EDIT
# These are rebuilt by portal/scripts/generate-all.sh from:
#   - OpenAPI specs (architecture/specs/*.yaml)
#   - YAML metadata (architecture/metadata/*.yaml)
#   - AsyncAPI specs (architecture/events/*.yaml)
# ===========================================================================

# Generated Swagger UI HTML pages
portal/docs/services/api/

# Specs copied to portal during build (source of truth: architecture/specs/)
portal/docs/specs/

# Generated microservice pages (MD + PUML + SVG)
portal/docs/microservices/*.md
portal/docs/microservices/puml/
portal/docs/microservices/svg/

# Generated application pages (MD + PUML + SVG)
portal/docs/applications/*.md
portal/docs/applications/puml/
portal/docs/applications/svg/

# Generated event UI pages
portal/docs/events-ui/

# Generated event catalog and actor catalog index pages
portal/docs/events/index.md
portal/docs/actors/index.md

# Generated standalone diagram SVGs
portal/docs/diagrams/svg/

# MkDocs build output
portal/site/
presentation/site/
site/

# Confluence staging output (generated by portal/scripts/confluence-prepare.py)
portal/confluence/

# Bicep ARM template build artifacts
infra/*.json
infra/modules/*.json

# Java / Gradle build artifacts
services/**/build/
services/**/.gradle/
*.class
*.jar
!**/gradle/wrapper/gradle-wrapper.jar

# Gradle bin directories (generated by ./gradlew)
services/**/bin/
