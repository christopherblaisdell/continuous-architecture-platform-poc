@startuml reservation-booking-flow
' NovaTrek Adventures - Reservation Booking Flow
' Full guest booking sequence from search to confirmation

title NovaTrek Adventures - Reservation Booking Flow

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2E86AB
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
}

' ============================================================
' Participants
' ============================================================
actor "Guest App" as guest
participant "API Gateway" as gateway
participant "svc-reservations" as reservations [[/services/svc-reservations/]]
participant "svc-trip-catalog" as catalog [[/services/svc-trip-catalog/]]
participant "svc-guest-profiles" as profiles [[/services/svc-guest-profiles/]]
participant "svc-gear-inventory" as gear
participant "svc-payments" as payments
participant "svc-notifications" as notifications
queue "Kafka" as kafka

' ============================================================
' Trip Search and Selection
' ============================================================
guest -> gateway : [[/services/svc-trip-catalog/ GET /trips?region=rockies&date=2026-06-15]]
gateway -> catalog : [[/services/svc-trip-catalog/ searchTrips(criteria)]]
catalog --> gateway : available trips list
gateway --> guest : display trip options

guest -> gateway : [[/services/svc-trip-catalog/ GET /trips/{tripId}/details]]
gateway -> catalog : [[/services/svc-trip-catalog/ getTripDetails(tripId)]]
catalog --> gateway : trip details + available dates
gateway --> guest : trip detail view

' ============================================================
' Guest Eligibility Validation
' ============================================================
guest -> gateway : [[/services/svc-reservations/ POST /reservations/validate]]
gateway -> reservations : [[/services/svc-reservations/ validateBooking(tripId, guestId)]]
reservations -> profiles : [[/services/svc-guest-profiles/ getGuestProfile(guestId)]]
profiles --> reservations : guest profile + certifications
reservations -> catalog : [[/services/svc-trip-catalog/ getTripRequirements(tripId)]]
catalog --> reservations : required certifications + fitness level

alt Guest meets all requirements
    reservations --> gateway : eligible = true
    gateway --> guest : proceed to gear selection
else Guest missing certification
    reservations --> gateway : eligible = false, reason: "Missing wilderness first aid cert"
    gateway --> guest : display ineligibility reason
end

' ============================================================
' Gear Package Selection
' ============================================================
guest -> gateway : GET /gear/packages?tripId={tripId}
gateway -> gear : getAvailablePackages(tripId, date)
gear --> gateway : gear package options
gateway --> guest : display gear packages

guest -> gateway : [[/services/svc-reservations/ POST /reservations/gear-selection]]
gateway -> reservations : [[/services/svc-reservations/ selectGearPackage(reservationDraft, packageId)]]
reservations -> gear : reserveGear(packageId, date)
gear --> reservations : gear hold confirmation (15 min TTL)
reservations --> gateway : gear reserved
gateway --> guest : proceed to payment

' ============================================================
' Reservation Creation and Payment
' ============================================================
guest -> gateway : [[/services/svc-reservations/ POST /reservations]]
gateway -> reservations : [[/services/svc-reservations/ createReservation(guestId, tripId, gearPackageId)]]
reservations -> reservations : calculate total (trip + gear + fees)
reservations -> payments : processPayment(amount, paymentMethod)

alt Payment successful
    payments --> reservations : payment confirmed (txnId)
    reservations -> reservations : status = CONFIRMED
    reservations -> kafka : publish reservation.created
    reservations --> gateway : reservation confirmation
    gateway --> guest : booking confirmed (reservationId)

    kafka -> notifications : consume reservation.created
    notifications -> notifications : generate confirmation email + SMS
    notifications --> guest : email confirmation + itinerary
else Payment declined
    payments --> reservations : payment declined (reason)
    reservations -> gear : releaseGearHold(holdId)
    gear --> reservations : gear released
    reservations --> gateway : payment failed
    gateway --> guest : display payment error, retry options
end

@enduml
