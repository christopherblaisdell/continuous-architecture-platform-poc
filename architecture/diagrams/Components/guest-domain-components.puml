@startuml guest-domain-components
' NovaTrek Adventures - Guest Domain Detailed Components
' Internal structure of svc-guest-profiles, svc-check-in, svc-loyalty-rewards

title NovaTrek Adventures - Guest Domain Components

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam roundCorner 8
skinparam defaultFontName "Segoe UI"

' ============================================================
' svc-guest-profiles
' ============================================================
package "svc-guest-profiles" #F0E8F4 {
    component "GuestProfileController" as gp_ctrl
    component "GuestProfileService" as gp_svc
    component "CertificationValidator" as gp_cert
    component "GuestRepository" as gp_repo
    component "GuestEventPublisher" as gp_pub
    database "guest-profiles-db" as gp_db
}

' ============================================================
' svc-check-in
' ============================================================
package "svc-check-in" #EDE8F4 {
    component "CheckInController" as ci_ctrl
    component "CheckInService" as ci_svc
    component "WristbandGenerator" as ci_wrist
    component "CheckInRepository" as ci_repo
    component "CheckInEventPublisher" as ci_pub
    database "checkin-db" as ci_db
}

' ============================================================
' svc-loyalty-rewards
' ============================================================
package "svc-loyalty-rewards" #EAE8F4 {
    component "LoyaltyController" as lr_ctrl
    component "LoyaltyService" as lr_svc
    component "PointsCalculator" as lr_calc
    component "TierEngine" as lr_tier
    component "LoyaltyRepository" as lr_repo
    database "loyalty-db" as lr_db
}

' ============================================================
' Kafka Topics
' ============================================================
queue "guest.registered" as topic_guest_reg
queue "checkin.completed" as topic_checkin
queue "loyalty.points.earned" as topic_loyalty

' ============================================================
' Internal Flows - svc-guest-profiles
' ============================================================
gp_ctrl --> gp_svc
gp_svc --> gp_cert
gp_svc --> gp_repo
gp_repo --> gp_db
gp_svc --> gp_pub
gp_pub --> topic_guest_reg

' ============================================================
' Internal Flows - svc-check-in
' ============================================================
ci_ctrl --> ci_svc
ci_svc --> ci_wrist
ci_svc --> ci_repo
ci_repo --> ci_db
ci_svc --> ci_pub
ci_pub --> topic_checkin

' ============================================================
' Internal Flows - svc-loyalty-rewards
' ============================================================
lr_ctrl --> lr_svc
lr_svc --> lr_calc
lr_svc --> lr_tier
lr_svc --> lr_repo
lr_repo --> lr_db
lr_svc ..> topic_loyalty : publish

' ============================================================
' Inter-Service Communication
' ============================================================
ci_svc --> gp_svc : "lookup guest profile"
lr_svc --> gp_svc : "get guest tier data"
topic_checkin ..> lr_svc : "trigger points calculation"

@enduml
