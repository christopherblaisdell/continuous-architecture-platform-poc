@startuml svc-gear-inventory--post-gear-assignments

!include ../theme.puml
skinparam sequence {
    ArrowColor #0891b2
}

header [[/microservices/svc-gear-inventory/#integration-context ⬆ svc-gear-inventory Integration Context]]

title POST /gear-assignments\nAssign gear to reservation\n<size:10><color:#7c3aed>ARCHITECT OVERRIDE — enriched with availability validation and reservation binding</color></size>

participant "Client" as Client [[/applications/]]
participant "svc-gear-inventory" as Svc [[/microservices/svc-gear-inventory/]] #CFFAFE
participant "Reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9
database "PostgreSQL" as DB [[/microservices/svc-gear-inventory/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-gear-inventory.html View in Swagger UI]]
end note

Client -> Svc : POST /gear-assignments\n{ reservation_id, gear_items[],\nassignment_date }
activate Svc #0891b2

par Parallel validation
    Svc -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details GET /reservations/{reservation_id}]]\nVerify reservation exists\nand is CONFIRMED
    activate Res #D1FAE5
    Res --> Svc : Reservation\n(status, guest_id,\nadventure_date)
    deactivate Res
    |||
    Svc -> DB : SELECT * FROM gear_items\nWHERE id IN (gear_items[])\nAND available_qty > 0
    activate DB #FEF9C3
    DB --> Svc : Available items\n(ids, quantities,\ncondition)
    deactivate DB
end

alt Any item unavailable
    Svc --> Client : 422 Unprocessable\n(unavailable_items[])
else All items available
    Svc -> DB : BEGIN TRANSACTION\nINSERT INTO gear_assignments\nUPDATE gear_items SET\navailable_qty -= 1
    activate DB #FEF9C3
    DB --> Svc : Committed
    deactivate DB

    Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification POST /notifications]]\nGear ready for pickup

    Svc --> Client : 201 Created\n(assignment_id, items[],\npickup_location)
    deactivate Svc
end

@enduml
