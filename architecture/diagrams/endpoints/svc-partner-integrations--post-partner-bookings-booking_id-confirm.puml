@startuml svc-partner-integrations--post-partner-bookings-booking_id-confirm

!include ../theme.puml
skinparam sequence {
    ArrowColor #9333ea
}

header [[/microservices/svc-partner-integrations/#integration-context ⬆ svc-partner-integrations Integration Context]]

title POST /partner-bookings/{booking_id}/confirm\nConfirm partner booking\n<size:10><color:#7c3aed>ARCHITECT OVERRIDE — enriched with commission logic and partner callback</color></size>

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-partner-integrations" as Svc [[/microservices/svc-partner-integrations/]] #F3E8FF
participant "Reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "Payments Svc" as Pay [[/microservices/svc-payments/]] #F1F5F9
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9
database "PostgreSQL" as DB [[/microservices/svc-partner-integrations/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-partner-integrations.html View in Swagger UI]]
end note

Client -> GW : POST /partner-bookings/{id}/confirm
activate GW #9333ea
GW -> Svc : route request
activate Svc #9333ea

note right of Svc : Load partner booking\nValidate status = PENDING\nVerify partner API key

Svc -> DB : SELECT FROM partner_bookings\nWHERE booking_id = ?
activate DB #FEF9C3
DB --> Svc : Partner booking\n(partner_id, reservation_id,\ncommission_rate, status)
deactivate DB

== Reservation Confirmation ==

Svc -> Res : [[/microservices/svc-reservations/#put-reservationsreservation_idstatus-update-reservation-status PUT /reservations/{id}/status]]\n(status = CONFIRMED)
activate Res #D1FAE5
alt Reservation confirmable
    Res --> Svc : Reservation confirmed
    deactivate Res
else Reservation already cancelled or expired
    Res --> Svc : 409 Conflict
    deactivate Res
    note right of Svc #FEE2E2 : Partner booking cannot\nbe confirmed — reservation\nis no longer valid
    Svc --> GW : 409 Conflict
    deactivate Svc
    GW --> Client : 409 Conflict
    deactivate GW
end

== Commission Payment ==

note right of Svc : Calculate commission:\ntotal_amount × commission_rate\n(rate set per partner agreement,\ntypically 10-20%)

Svc -[#DC2626]> Pay : [[/microservices/svc-payments/#post-payments-process-a-payment POST /payments]]\n(type = COMMISSION,\namount = calculated_commission,\npayee = partner_account)
activate Pay #F1F5F9
Pay --> Svc : Commission payment processed\n(payment_id)
deactivate Pay

== Update Booking Record ==

Svc -> DB : UPDATE partner_bookings\nSET status = CONFIRMED,\ncommission_payment_id,\nconfirmed_at
activate DB #FEF9C3
DB --> Svc : Updated
deactivate DB

== Async Partner Callback ==

Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send partner confirmation]]\n(booking details + commission receipt)

Svc --> GW : 200 OK\n(booking_id, status = CONFIRMED,\ncommission_amount)
deactivate Svc
GW --> Client : 200 OK
deactivate GW

@enduml
