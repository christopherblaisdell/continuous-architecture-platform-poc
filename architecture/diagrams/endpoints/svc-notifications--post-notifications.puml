@startuml svc-notifications--post-notifications

!include ../theme.puml
skinparam sequence {
    ArrowColor #64748b
}

header [[/microservices/svc-notifications/#integration-context ⬆ svc-notifications Integration Context]]

title POST /notifications\nSend a notification\n<size:10><color:#7c3aed>ARCHITECT OVERRIDE — enriched with multi-channel dispatch and preference routing</color></size>

participant "Caller Service" as Client [[/applications/]]
participant "svc-notifications" as Svc [[/microservices/svc-notifications/]] #F1F5F9
participant "Guest Profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE
queue "SendGrid" as Email #F1F5F9
queue "Twilio" as SMS #F1F5F9
queue "FCM" as Push #F1F5F9
database "PostgreSQL" as DB [[/microservices/svc-notifications/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-notifications.html View in Swagger UI]]
end note

Client -> Svc : POST /notifications\n{ guest_id, template,\nchannel_override?, payload }
activate Svc #64748b

Svc -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile-by-id GET /guests/{guest_id}]]\nResolve contact info +\nchannel preferences
activate GP #EDE9FE
GP --> Svc : Guest profile\n(email, phone,\npreferred_channels[])
deactivate GP

note right of Svc : Channel selection:\n1. channel_override if set\n2. guest preferred_channels\n3. fallback: email

Svc -> DB : INSERT INTO notifications\n(template, guest_id, channels,\nstatus = PENDING)
activate DB #FEF9C3
DB --> Svc : notification_id
deactivate DB

par Dispatch to selected channels
    opt Email channel
        Svc ->> Email : Send email\n(template, payload)
    end
    opt SMS channel
        Svc ->> SMS : Send SMS\n(template, payload)
    end
    opt Push channel
        Svc ->> Push : Send push\n(template, payload)
    end
end

Svc -> DB : UPDATE notifications\nSET status = SENT,\nchannels_dispatched = [...]
activate DB #FEF9C3
DB --> Svc : Updated
deactivate DB

Svc --> Client : 201 Created\n(notification_id, channels_used,\nstatus)
deactivate Svc

@enduml
