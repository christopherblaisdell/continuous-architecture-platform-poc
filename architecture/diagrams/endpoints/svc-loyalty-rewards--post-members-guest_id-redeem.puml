@startuml svc-loyalty-rewards--post-members-guest_id-redeem

!include ../theme.puml
skinparam sequence {
    ArrowColor #64748b
}

header [[/microservices/svc-loyalty-rewards/#integration-context ⬆ svc-loyalty-rewards Integration Context]]

title POST /members/{guest_id}/redeem\nRedeem loyalty points\n<size:10><color:#7c3aed>ARCHITECT OVERRIDE — enriched with ledger consistency and optimistic locking</color></size>

participant "Client" as Client [[/applications/]]
participant "svc-loyalty-rewards" as Svc [[/microservices/svc-loyalty-rewards/]] #F1F5F9
participant "Kafka" as Kafka [[/architecture/events/]] #F5F3FF
database "Couchbase" as DB [[/microservices/svc-loyalty-rewards/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-loyalty-rewards.html View in Swagger UI]]
end note

Client -> Svc : POST /members/{guest_id}/redeem\n{ points, reward_type,\nredemption_code }
activate Svc #64748b

Svc -> DB : GET member:{guest_id}\n(with CAS value for\noptimistic locking)
activate DB #FEF9C3
DB --> Svc : Member doc\n(balance, tier, _cas)
deactivate DB

alt Insufficient balance
    Svc --> Client : 422 Unprocessable\n(insufficient_points,\navailable = balance)
else Sufficient balance
    note right of Svc : Debit points atomically\nbalance -= points\nAppend to ledger array

    Svc -> DB : REPLACE member:{guest_id}\nWITH CAS check\n(updated balance, ledger entry)
    activate DB #FEF9C3
    alt CAS mismatch (concurrent modification)
        DB --> Svc : CAS_MISMATCH
        deactivate DB
        Svc --> Client : 409 Conflict\n(retry_required)
    else CAS match
        DB --> Svc : Success
        deactivate DB

        Svc ->> Kafka : loyalty.points.redeemed\n(guest_id, points, reward_type)

        Svc --> Client : 200 OK\n(redemption_id, new_balance,\ntier)
        deactivate Svc
    end
end

@enduml
