@startuml svc-loyalty-rewards--post-members-guest_id-earn

!include ../theme.puml
skinparam sequence {
    ArrowColor #64748b
}

header [[/microservices/svc-loyalty-rewards/#integration-context ⬆ svc-loyalty-rewards Integration Context]]

title POST /members/{guest_id}/earn\nEarn loyalty points\n<size:10><color:#7c3aed>ARCHITECT OVERRIDE — enriched with tier-multiplier and booking validation</color></size>

participant "Client" as Client [[/applications/]]
participant "svc-loyalty-rewards" as Svc [[/microservices/svc-loyalty-rewards/]] #F1F5F9
participant "Reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "Kafka" as Kafka [[/architecture/events/]] #F5F3FF
database "Couchbase" as DB [[/microservices/svc-loyalty-rewards/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-loyalty-rewards.html View in Swagger UI]]
end note

Client -> Svc : POST /members/{guest_id}/earn\n{ booking_id, base_points,\nearning_reason }
activate Svc #64748b

Svc -> DB : GET member:{guest_id}
activate DB #FEF9C3
DB --> Svc : Member doc\n(tier, balance)
deactivate DB

note right of Svc : Apply tier multiplier:\nBronze = 1.0x\nSilver = 1.25x\nGold = 1.5x\nPlatinum = 2.0x

Svc -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details GET /reservations/{booking_id}]]\nVerify booking is COMPLETED
activate Res #D1FAE5
Res --> Svc : Reservation\n(status, guest_id)
deactivate Res

alt Booking not COMPLETED or guest mismatch
    Svc --> Client : 422 Unprocessable\n(booking_not_eligible)
else Valid earning
    Svc -> DB : UPDATE member:{guest_id}\nbalance += adjusted_points\nAppend ledger entry
    activate DB #FEF9C3
    DB --> Svc : Success
    deactivate DB

    Svc ->> Kafka : loyalty.points.earned\n(guest_id, points, tier)

    Svc --> Client : 200 OK\n(points_earned, new_balance,\ntier, multiplier_applied)
    deactivate Svc
end

@enduml
