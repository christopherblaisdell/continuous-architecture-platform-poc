@startuml svc-transport-logistics--post-transport-requests

!include ../theme.puml
skinparam sequence {
    ArrowColor #0891b2
}

header [[/microservices/svc-transport-logistics/#integration-context ⬆ svc-transport-logistics Integration Context]]

title POST /transport-requests\nSubmit transport request\n<size:10><color:#7c3aed>ARCHITECT OVERRIDE — enriched with route optimization and vehicle tracking</color></size>

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-transport-logistics" as Svc [[/microservices/svc-transport-logistics/]] #CFFAFE
participant "Reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "Location Svc" as LS [[/microservices/svc-location-services/]] #F1F5F9
participant "Google Maps" as ExtMap #F3E8FF
participant "Fleet GPS" as FleetGPS #F3E8FF
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9
database "PostgreSQL" as DB [[/microservices/svc-transport-logistics/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-transport-logistics.html View in Swagger UI]]
end note

Client -> GW : POST /transport-requests
activate GW #0891b2
GW -> Svc : route request
activate Svc #0891b2

note right of Svc : Validate request\n(reservation_id, pickup_location,\ndropoff_location, passenger_count)

== Booking Verification ==

Svc -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details GET /reservations/{id}]]
activate Res #D1FAE5
Res --> Svc : Reservation details\n(guest_count, trip_date,\nstatus = CONFIRMED)
deactivate Res

== Location Validation ==

Svc -> LS : [[/microservices/svc-location-services/#get-locationslocation_id-get-location-details GET /locations/{id}]]
activate LS #F1F5F9
LS --> Svc : Pickup coordinates\n(lat, lng, access_type)
deactivate LS

note right of Svc : Validate pickup is\naccessible by vehicle\n(road access required)

== Route Optimization ==

Svc -> ExtMap : Calculate optimal route\n(pickup → dropoff,\nconsider traffic, road closures)
activate ExtMap #F3E8FF
ExtMap --> Svc : Route details\n(distance, duration, waypoints,\ntraffic_delay)
deactivate ExtMap

== Vehicle Assignment ==

Svc -> FleetGPS : Get real-time vehicle\nlocations and ETAs
activate FleetGPS #F3E8FF
alt Fleet GPS available
    FleetGPS --> Svc : Vehicle positions\n(vehicle_id, lat, lng,\nstatus, capacity)
    deactivate FleetGPS

    note right of Svc : Select vehicle by:\n1. Nearest to pickup\n2. Capacity >= passenger_count\n3. Available (not en-route)\n4. Fuel level adequate
else Fleet GPS unavailable
    FleetGPS --> Svc : 503 / timeout
    deactivate FleetGPS
    note right of Svc #FEF3C7 : Fallback: assign from\nstatic vehicle roster\n(last known depot location)
end

== Database ==

Svc -> DB : INSERT INTO transport_requests\n(request_id, reservation_id,\nassigned_vehicle, route,\nestimated_pickup_time,\nstatus = SCHEDULED)
activate DB #FEF9C3
DB --> Svc : Created row
deactivate DB

== Async Notification ==

Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send transport details]]\n(pickup time, vehicle info, route)

Svc --> GW : 201 Created\n(request_id, vehicle,\nestimated_pickup, route_duration)
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml
