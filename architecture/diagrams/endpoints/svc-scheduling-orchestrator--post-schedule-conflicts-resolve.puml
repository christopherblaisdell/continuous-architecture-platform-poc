@startuml svc-scheduling-orchestrator--post-schedule-conflicts-resolve

!include ../theme.puml
skinparam sequence {
    ArrowColor #2563eb
}

header [[/microservices/svc-scheduling-orchestrator/#integration-context ⬆ svc-scheduling-orchestrator Integration Context]]

title POST /schedule-conflicts/resolve\nResolve scheduling conflict\n<size:10><color:#7c3aed>ARCHITECT OVERRIDE — enriched with guide reassignment and notification cascade</color></size>

participant "Ops Staff" as Client [[/actors/#operations-staff]]
participant "svc-scheduling-orchestrator" as Svc [[/microservices/svc-scheduling-orchestrator/]] #DBEAFE
participant "Guide Mgmt" as GM [[/microservices/svc-guide-management/]] #E0E7FF
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9
database "PostgreSQL" as DB [[/microservices/svc-scheduling-orchestrator/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-scheduling-orchestrator.html View in Swagger UI]]
end note

Client -> Svc : POST /schedule-conflicts/resolve\n{ conflict_id,\nresolution_strategy,\nreplacement_guide_id? }
activate Svc #2563eb

Svc -> DB : SELECT * FROM schedule_conflicts\nWHERE id = conflict_id
activate DB #FEF9C3
DB --> Svc : Conflict record\n(type, affected_slot,\noriginal_guide_id)
deactivate DB

alt Resolution = REASSIGN_GUIDE
    Svc -> GM : [[/microservices/svc-guide-management/#get-guidesguide_id-get-guide-details GET /guides/{replacement_guide_id}]]\nVerify availability + certs
    activate GM #E0E7FF
    GM --> Svc : Guide profile\n(certifications[],\navailability)
    deactivate GM

    note right of Svc : Validate guide holds\nrequired certifications\nfor adventure type

    Svc -> DB : UPDATE daily_schedule\nSET guide_id = replacement\nWHERE slot = affected_slot
    activate DB #FEF9C3
    DB --> Svc : Updated
    deactivate DB
else Resolution = CANCEL_SLOT
    Svc -> DB : UPDATE daily_schedule\nSET status = CANCELLED\nWHERE slot = affected_slot
    activate DB #FEF9C3
    DB --> Svc : Updated
    deactivate DB
end

Svc -> DB : UPDATE schedule_conflicts\nSET status = RESOLVED,\nresolution = strategy
activate DB #FEF9C3
DB --> Svc : Updated
deactivate DB

Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification POST /notifications]]\nNotify affected guides + guests

Svc --> Client : 200 OK\n(conflict_id, resolution,\nupdated_slot)
deactivate Svc

@enduml
