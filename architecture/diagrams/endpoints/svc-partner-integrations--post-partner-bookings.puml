@startuml svc-partner-integrations--post-partner-bookings

!include ../theme.puml
skinparam sequence {
    ArrowColor #9333ea
}

header [[/microservices/svc-partner-integrations/#integration-context ⬆ svc-partner-integrations Integration Context]]

title POST /partner-bookings\nCreate partner booking\n<size:10><color:#7c3aed>ARCHITECT OVERRIDE — enriched with partner eligibility and commission tier</color></size>

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-partner-integrations" as Svc [[/microservices/svc-partner-integrations/]] #F3E8FF
participant "Guest Profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE
participant "Trip Catalog" as TC [[/microservices/svc-trip-catalog/]] #FEF3C7
participant "Reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
database "PostgreSQL" as DB [[/microservices/svc-partner-integrations/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-partner-integrations.html View in Swagger UI]]
end note

Client -> GW : POST /partner-bookings
activate GW #9333ea
GW -> Svc : route request
activate Svc #9333ea

note right of Svc : Validate API key\nLoad partner account

Svc -> DB : SELECT FROM partners\nWHERE api_key_hash = ?
activate DB #FEF9C3
DB --> Svc : Partner record\n(partner_id, status,\ncommission_tier, daily_quota)
deactivate DB

alt Partner suspended or over daily quota
    note right of Svc #FEE2E2 : Reject: partner account\nnot active or quota exceeded
    Svc --> GW : 403 Forbidden
    deactivate Svc
    GW --> Client : 403 Forbidden
    deactivate GW
end

== Guest Validation ==

Svc -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile GET /guests/{guest_id}]]
activate GP #EDE9FE
GP --> Svc : Guest profile
deactivate GP

== Trip Availability ==

Svc -> TC : [[/microservices/svc-trip-catalog/#get-tripstrip_id-get-trip-details GET /trips/{trip_id}]]
activate TC #FEF3C7
TC --> Svc : Trip details\n(availability, pricing)
deactivate TC

== Create Reservation ==

note right of Svc : Apply partner commission tier:\n- Gold: 15% commission\n- Silver: 12% commission\n- Bronze: 10% commission\nInclude partner_ref in reservation

Svc -> Res : [[/microservices/svc-reservations/#post-reservations-create-a-new-reservation POST /reservations]]\n(guest_id, trip_id,\npartner_ref, channel = PARTNER)
activate Res #D1FAE5
Res --> Svc : Reservation created\n(reservation_id, confirmation_code)
deactivate Res

== Record Partner Booking ==

Svc -> DB : INSERT INTO partner_bookings\n(booking_id, partner_id,\nreservation_id, commission_tier,\ncommission_rate, status = PENDING)
activate DB #FEF9C3
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created\n(booking_id, reservation_id,\nconfirmation_code, status)
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml
