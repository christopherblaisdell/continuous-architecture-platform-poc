@startuml svc-payments--post-payments

!include ../theme.puml
skinparam sequence {
    ArrowColor #dc2626
}

header [[/microservices/svc-payments/#integration-context ⬆ svc-payments Integration Context]]

title POST /payments\nProcess payment transaction\n<size:10><color:#7c3aed>ARCHITECT OVERRIDE — enriched with fraud detection and gateway fallback</color></size>

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-payments" as Svc [[/microservices/svc-payments/]] #F1F5F9
participant "Currency Exchange" as FX #F3E8FF
participant "Fraud Detection" as FD #F3E8FF
participant "Payment Gateway" as PGW #F3E8FF
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9
database "PostgreSQL" as DB [[/microservices/svc-payments/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-payments.html View in Swagger UI]]
end note

Client -> GW : POST /payments
activate GW #dc2626
GW -> Svc : route request
activate Svc #dc2626

note right of Svc : Validate payment request\n(amount, currency, guest_id,\nreservation_id, payment_method)\nIdempotency check via\nidempotency_key header

Svc -> DB : SELECT FROM payments\nWHERE idempotency_key = ?
activate DB #FEF9C3
DB --> Svc : null (new) or existing payment
deactivate DB

alt Idempotent duplicate detected
    note right of Svc : Return cached response\n(prevents double-charge)
    Svc --> GW : 200 OK (cached)
else New payment

    == Currency Conversion ==

    alt Currency != base currency (USD)
        Svc -> FX : Convert {currency}\nto USD at spot rate
        activate FX #F3E8FF
        FX --> Svc : Converted amount\n+ exchange rate + timestamp
        deactivate FX
        note right of Svc : Lock exchange rate\nfor 15 min window
    else Already in USD
        note right of Svc : No conversion needed
    end

    == Fraud Screening (fail-fast gate) ==

    Svc -[#DC2626]> FD : Screen transaction\n(amount, guest history,\nIP, device fingerprint)
    activate FD #F3E8FF
    alt Fraud score < 30 (APPROVED)
        FD --> Svc : APPROVED\n(risk_score, factors)
        deactivate FD
    else Fraud score 30-70 (REVIEW)
        FD --> Svc : REVIEW\n(risk_score, factors)
        deactivate FD
        note right of Svc #FEF3C7 : Flag for manual review\nPayment held, not charged\nStatus = PENDING_REVIEW
        Svc -> DB : INSERT INTO payments\n(status = PENDING_REVIEW,\nfraud_score, hold_reason)
        activate DB #FEF9C3
        DB --> Svc : Created
        deactivate DB
        Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Notify fraud review team]]
        Svc --> GW : 202 Accepted\n(payment_id, status = PENDING_REVIEW)
        deactivate Svc
        GW --> Client : 202 Accepted
        deactivate GW
    else Fraud score > 70 (DECLINED)
        FD --> Svc : DECLINED\n(risk_score, factors)
        deactivate FD
        note right of Svc #FEE2E2 : Payment rejected\nLog fraud attempt
        Svc -> DB : INSERT INTO payments\n(status = DECLINED,\nfraud_score, decline_reason)
        activate DB #FEF9C3
        DB --> Svc : Created
        deactivate DB
        Svc --> GW : 422 Unprocessable\n(decline_reason)
        deactivate Svc
        GW --> Client : 422 Unprocessable
        deactivate GW
    end

    == Payment Gateway (approved transactions only) ==

    Svc -[#DC2626]> PGW : Tokenize & route payment\n(card token, amount_usd,\nmerchant_id)
    activate PGW #F3E8FF
    alt Gateway success
        PGW --> Svc : Payment confirmed\n(transaction_id, auth_code)
        deactivate PGW
    else Gateway timeout or failure
        PGW --> Svc : 503 / timeout
        deactivate PGW
        note right of Svc #FEE2E2 : Mark as FAILED\nDo NOT retry automatically\n(risk of double-charge)\nReturn error to caller
        Svc -> DB : INSERT INTO payments\n(status = FAILED,\ngateway_error)
        activate DB #FEF9C3
        DB --> Svc : Created
        deactivate DB
        Svc --> GW : 502 Bad Gateway
        deactivate Svc
        GW --> Client : 502 Bad Gateway
        deactivate GW
    end

    == Record Successful Payment ==

    group Transaction boundary (PostgreSQL)
        Svc -> DB : INSERT INTO payments\n(payment_id, amount, currency,\nexchange_rate, fraud_score,\ngateway_txn_id, status = COMPLETED)
        activate DB #FEF9C3
        DB --> Svc : Created row
        deactivate DB

        Svc -> DB : INSERT INTO payment_ledger\n(debit entry, credit entry)
        activate DB #FEF9C3
        DB --> Svc : Ledger entries created
        deactivate DB
    end

    == Async Receipt ==

    Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send payment receipt]]

    Svc --> GW : 201 Created\n(payment_id, status = COMPLETED,\ntransaction_id)
    deactivate Svc
    GW --> Client : 201 Created
    deactivate GW
end

@enduml
