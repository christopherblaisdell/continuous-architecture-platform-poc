@startuml svc-reservations--post-reservations

!include ../theme.puml
skinparam sequence {
    ArrowColor #059669
}

header [[/microservices/svc-reservations/#integration-context ⬆ svc-reservations Integration Context]]

title POST /reservations\nCreate a new reservation\n<size:10><color:#7c3aed>ARCHITECT OVERRIDE — enriched with eligibility gates and payment flow</color></size>

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-reservations" as Svc [[/microservices/svc-reservations/]] #D1FAE5
participant "Guest Profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE
participant "Trip Catalog" as TC [[/microservices/svc-trip-catalog/]] #FEF3C7
participant "Payments Svc" as Pay [[/microservices/svc-payments/]] #F1F5F9
participant "Event Bus" as Kafka #F5F3FF
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9
database "PostgreSQL" as DB [[/microservices/svc-reservations/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-reservations.html View in Swagger UI]]
end note

Client -> GW : POST /reservations
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body\n(guest_id, trip_id, travel_date,\nparticipant_count required)

== Guest Eligibility ==

Svc -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile GET /guests/{guest_id}]]
activate GP #EDE9FE
GP --> Svc : Guest profile\n(status, age, restrictions)
deactivate GP

alt Guest account suspended or incomplete
    note right of Svc #FEE2E2 : Reject: guest not eligible\n(account status != ACTIVE)
    Svc --> GW : 422 Unprocessable\n(reason: GUEST_NOT_ELIGIBLE)
    deactivate Svc
    GW --> Client : 422 Unprocessable
    deactivate GW
end

== Trip Availability ==

Svc -> TC : [[/microservices/svc-trip-catalog/#get-tripstrip_id-get-trip-details GET /trips/{trip_id}]]
activate TC #FEF3C7
TC --> Svc : Trip details\n(capacity, booked_count,\nprice, adventure_category)
deactivate TC

alt Trip fully booked
    note right of Svc #FEE2E2 : Reject: no capacity\nremaining for requested date
    Svc --> GW : 409 Conflict\n(reason: TRIP_FULLY_BOOKED)
    deactivate Svc
    GW --> Client : 409 Conflict
    deactivate GW
else Trip has capacity
    note right of Svc : Calculate total:\nparticipant_count × price_per_person\n+ applicable taxes/fees\n\nHold capacity (optimistic lock)
end

== Deposit Payment ==

Svc -[#DC2626]> Pay : [[/microservices/svc-payments/#post-payments-process-a-payment POST /payments]]\n(deposit = 25% of total,\nguest payment method)
activate Pay #F1F5F9
alt Payment successful
    Pay --> Svc : Payment confirmed\n(payment_id, transaction_id)
    deactivate Pay
else Payment failed
    Pay --> Svc : Payment failed\n(decline_reason)
    deactivate Pay
    note right of Svc #FEE2E2 : Release capacity hold\nReturn payment error to caller
    Svc --> GW : 422 Unprocessable\n(reason: PAYMENT_FAILED,\ndetails)
    deactivate Svc
    GW --> Client : 422 Unprocessable
    deactivate GW
end

== Create Reservation Record ==

group Transaction boundary (PostgreSQL)
    Svc -> DB : INSERT INTO reservations\n(reservation_id, guest_id,\ntrip_id, travel_date,\nparticipant_count, total_amount,\ndeposit_payment_id,\nstatus = CONFIRMED)
    activate DB #FEF9C3
    DB --> Svc : Created row
    deactivate DB

    Svc -> DB : UPDATE trip_availability\nSET booked_count += participant_count\nWHERE trip_id = ? AND date = ?
    activate DB #FEF9C3
    DB --> Svc : Updated
    deactivate DB
end

== Async Events ==

Svc ->> Kafka : reservation.created\n(reservation_id, guest_id,\ntrip_id, adventure_category)
Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send booking confirmation]]

Svc --> GW : 201 Created\n(reservation_id, status,\nconfirmation_code, total_amount)
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml
