@startuml svc-weather--get-weather-alerts

!include ../theme.puml
skinparam sequence {
    ArrowColor #64748b
}

header [[/microservices/svc-weather/#integration-context ⬆ svc-weather Integration Context]]

title GET /weather/alerts\nGet active weather alerts\n<size:10><color:#7c3aed>ARCHITECT OVERRIDE — enriched with severity threshold gating and cache strategy</color></size>

participant "Client" as Client [[/applications/]]
participant "svc-weather" as Svc [[/microservices/svc-weather/]] #F1F5F9
participant "External Weather API" as WX #F3E8FF
database "Valkey Cache" as Cache [[/microservices/svc-weather/#data-store]] #FECDD3
database "PostgreSQL" as DB [[/microservices/svc-weather/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-weather.html View in Swagger UI]]
end note

Client -> Svc : GET /weather/alerts\n?region={region}\n&min_severity={severity}
activate Svc #64748b

Svc -> Cache : GET weather:alerts:{region}
activate Cache #FECDD3
alt Cache hit (TTL < 5 min)
    Cache --> Svc : Cached alerts[]
    deactivate Cache
else Cache miss
    Cache --> Svc : null
    deactivate Cache

    Svc -> WX : Fetch alerts\n(region, coordinates)
    activate WX #F3E8FF
    WX --> Svc : Raw alerts[]\n(type, severity, expires)
    deactivate WX

    Svc -> Cache : SET weather:alerts:{region}\nTTL = 300s
    activate Cache #FECDD3
    Cache --> Svc : OK
    deactivate Cache

    Svc -> DB : INSERT INTO alert_log\n(region, alert_count,\nfetched_at)
    activate DB #FEF9C3
    DB --> Svc : Logged
    deactivate DB
end

note right of Svc : Filter by min_severity:\nLOW < MODERATE < HIGH < EXTREME\nReturn only alerts ≥ threshold

Svc --> Client : 200 OK\n(alerts[], region,\ncache_age_seconds)
deactivate Svc

@enduml
