@startuml svc-payments--post-payments-payment_id-refund

!include ../theme.puml
skinparam sequence {
    ArrowColor #64748b
}

header [[/microservices/svc-payments/#integration-context ⬆ svc-payments Integration Context]]

title POST /payments/{payment_id}/refund\nProcess payment refund\n<size:10><color:#7c3aed>ARCHITECT OVERRIDE — enriched with refund policy routing and partial refund support</color></size>

participant "Client" as Client [[/applications/]]
participant "svc-payments" as Svc [[/microservices/svc-payments/]] #F1F5F9
participant "Payment Gateway" as PG #F3E8FF
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9
database "PostgreSQL" as DB [[/microservices/svc-payments/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-payments.html View in Swagger UI]]
end note

Client -> Svc : POST /payments/{payment_id}/refund\n{ reason, amount? }
activate Svc #64748b

Svc -> DB : SELECT * FROM payments\nWHERE id = payment_id
activate DB #FEF9C3
DB --> Svc : Payment record\n(status, amount,\nmethod, guest_id)
deactivate DB

alt Payment not COMPLETED
    Svc --> Client : 422 Unprocessable\n(payment_not_refundable)
else COMPLETED
    note right of Svc : **Refund Policy Routing**\nFull refund: amount = null\nPartial refund: amount ≤ original\nPolicy: >24h before = 100%\n12-24h = 50%, <12h = 0%

    Svc -> PG : Process refund\n(original_txn_id,\nrefund_amount, method)
    activate PG #F3E8FF
    alt Refund approved
        PG --> Svc : Refund processed\n(refund_txn_id)
        deactivate PG

        Svc -> DB : INSERT INTO refunds\n(payment_id, amount,\nrefund_txn_id, reason)\nUPDATE payments\nSET status = REFUNDED
        activate DB #FEF9C3
        DB --> Svc : Committed
        deactivate DB

        Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification POST /notifications]]\nRefund confirmation to guest

        Svc --> Client : 200 OK\n(refund_id, amount_refunded,\nstatus)
        deactivate Svc
    else Refund declined by gateway
        PG --> Svc : Declined\n(decline_reason)
        deactivate PG
        Svc --> Client : 502 Bad Gateway\n(refund_declined,\ngateway_reason)
        deactivate Svc
    end
end

@enduml
