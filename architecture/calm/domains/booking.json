{
  "$schema": "https://calm.finos.org/release/1.2/meta/calm.json",
  "nodes": [
    {
      "unique-id": "svc-reservations",
      "node-type": "service",
      "name": "Reservations Service",
      "description": "Manages adventure trip reservations for NovaTrek Adventures.",
      "interfaces": [
        {
          "unique-id": "svc-reservations-api-get-reservations",
          "method": "GET",
          "path": "/reservations",
          "summary": "Search reservations"
        },
        {
          "unique-id": "svc-reservations-api-post-reservations",
          "method": "POST",
          "path": "/reservations",
          "summary": "Create a new reservation"
        },
        {
          "unique-id": "svc-reservations-api-get-reservations-{reservation_id}",
          "method": "GET",
          "path": "/reservations/{reservation_id}",
          "summary": "Get reservation details"
        },
        {
          "unique-id": "svc-reservations-api-patch-reservations-{reservation_id}",
          "method": "PATCH",
          "path": "/reservations/{reservation_id}",
          "summary": "Update a reservation"
        },
        {
          "unique-id": "svc-reservations-api-delete-reservations-{reservation_id}",
          "method": "DELETE",
          "path": "/reservations/{reservation_id}",
          "summary": "Cancel a reservation"
        },
        {
          "unique-id": "svc-reservations-api-get-reservations-{reservation_id}-participants",
          "method": "GET",
          "path": "/reservations/{reservation_id}/participants",
          "summary": "Get reservation participants"
        },
        {
          "unique-id": "svc-reservations-api-post-reservations-{reservation_id}-participants",
          "method": "POST",
          "path": "/reservations/{reservation_id}/participants",
          "summary": "Add a participant to a reservation"
        },
        {
          "unique-id": "svc-reservations-api-put-reservations-{reservation_id}-status",
          "method": "PUT",
          "path": "/reservations/{reservation_id}/status",
          "summary": "Transition reservation status"
        },
        {
          "unique-id": "svc-reservations-event-reservation-created",
          "channel": "novatrek.booking.reservation.created",
          "protocol": "Kafka",
          "role": "producer"
        },
        {
          "unique-id": "svc-reservations-event-reservation-status_changed",
          "channel": "novatrek.booking.reservation.status-changed",
          "protocol": "Kafka",
          "role": "producer"
        }
      ],
      "metadata": {
        "domain": "Booking",
        "team": "Booking Platform Team"
      }
    },
    {
      "unique-id": "svc-reservations-db",
      "node-type": "database",
      "name": "Reservations Database",
      "description": "PostgreSQL 15 database for svc-reservations (reservations schema)",
      "interfaces": [
        {
          "unique-id": "svc-reservations-db-jdbc",
          "host": "reservations-db.novatrek.internal",
          "port": 27017
        }
      ],
      "metadata": {
        "domain": "Booking",
        "engine": "PostgreSQL 15",
        "schema": "reservations",
        "tables": [
          "reservations",
          "participants",
          "status_history"
        ]
      }
    },
