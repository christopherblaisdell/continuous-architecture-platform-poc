  "relationships": [
    {
      "unique-id": "rel-svc-transport-logistics-to-db",
      "description": "svc-transport-logistics connects to its owned database",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "svc-transport-logistics"
          },
          "destination": {
            "node": "svc-transport-logistics-db"
          }
        }
      },
      "protocol": "JDBC"
    },
    {
      "unique-id": "rel-svc-gear-inventory-to-db",
      "description": "svc-gear-inventory connects to its owned database",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "svc-gear-inventory"
          },
          "destination": {
            "node": "svc-gear-inventory-db"
          }
        }
      },
      "protocol": "JDBC"
    },
    {
      "unique-id": "rel-svc-check-in-post--check-ins-{check_in_id}-gear-verification-to-svc-gear-inventory",
      "description": "Verify gear assignment",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "svc-check-in"
          },
          "destination": {
            "node": "svc-gear-inventory"
          }
        }
      },
      "protocol": "HTTPS",
      "metadata": {
        "source-endpoint": "POST /check-ins/{check_in_id}/gear-verification",
        "target-endpoint": "GET /gear-assignments/{assignment_id}",
        "async": false
      }
    },
    {
      "unique-id": "rel-svc-gear-inventory-post--gear-assignments-to-svc-guest-profiles",
      "description": "Validate guest",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "svc-gear-inventory"
          },
          "destination": {
            "node": "svc-guest-profiles"
          }
        }
      },
      "protocol": "HTTPS",
      "metadata": {
        "source-endpoint": "POST /gear-assignments",
        "target-endpoint": "GET /guests/{guest_id}",
        "async": false
      }
    },
    {
      "unique-id": "rel-svc-gear-inventory-post--gear-assignments-to-svc-reservations",
      "description": "Verify booking",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "svc-gear-inventory"
          },
          "destination": {
            "node": "svc-reservations"
          }
        }
      },
      "protocol": "HTTPS",
      "metadata": {
        "source-endpoint": "POST /gear-assignments",
        "target-endpoint": "GET /reservations/{reservation_id}",
        "async": false
      }
    },
    {
      "unique-id": "rel-svc-gear-inventory-post--gear-assignments-to-svc-safety-compliance",
      "description": "Check waiver status",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "svc-gear-inventory"
          },
          "destination": {
            "node": "svc-safety-compliance"
          }
        }
      },
