{
  "$schema": "https://calm.finos.org/release/1.2/meta/calm.json",
  "nodes": [
    {
      "unique-id": "svc-transport-logistics",
      "node-type": "service",
      "name": "Transport Logistics Service",
      "description": "Manages shuttle buses, van pickups, and transport coordination between NovaTrek",
      "interfaces": [
        {
          "unique-id": "svc-transport-logistics-api-get-routes",
          "method": "GET",
          "path": "/routes",
          "summary": "List transport routes"
        },
        {
          "unique-id": "svc-transport-logistics-api-post-routes",
          "method": "POST",
          "path": "/routes",
          "summary": "Create a new transport route"
        },
        {
          "unique-id": "svc-transport-logistics-api-get-routes-{route_id}-schedule",
          "method": "GET",
          "path": "/routes/{route_id}/schedule",
          "summary": "Get schedule for a transport route"
        },
        {
          "unique-id": "svc-transport-logistics-api-post-transport-requests",
          "method": "POST",
          "path": "/transport-requests",
          "summary": "Request transport for a reservation"
        },
        {
          "unique-id": "svc-transport-logistics-api-get-transport-requests-{request_id}",
          "method": "GET",
          "path": "/transport-requests/{request_id}",
          "summary": "Get transport request details"
        },
        {
          "unique-id": "svc-transport-logistics-api-get-vehicles",
          "method": "GET",
          "path": "/vehicles",
          "summary": "List fleet vehicles"
        },
        {
          "unique-id": "svc-transport-logistics-api-patch-vehicles-{vehicle_id}",
          "method": "PATCH",
          "path": "/vehicles/{vehicle_id}",
          "summary": "Update vehicle information"
        }
      ],
      "metadata": {
        "domain": "Logistics",
        "team": "Logistics Team"
      }
    },
    {
      "unique-id": "svc-transport-logistics-db",
      "node-type": "database",
      "name": "Transport Logistics Database",
      "description": "PostgreSQL 15 database for svc-transport-logistics (transport schema)",
      "interfaces": [
        {
          "unique-id": "svc-transport-logistics-db-jdbc",
          "host": "transport-logistics-db.novatrek.internal",
          "port": 27017
        }
      ],
      "metadata": {
        "domain": "Logistics",
        "engine": "PostgreSQL 15",
        "schema": "transport",
        "tables": [
          "routes",
          "route_schedules",
          "transport_requests",
          "vehicles"
        ]
      }
    },
