    {
      "unique-id": "svc-trip-catalog",
      "node-type": "service",
      "name": "Trip Catalog Service",
      "description": "Manages adventure trip definitions, scheduling, pricing, and availability",
      "interfaces": [
        {
          "unique-id": "svc-trip-catalog-api-get-trips",
          "method": "GET",
          "path": "/trips",
          "summary": "Search trips with filters"
        },
        {
          "unique-id": "svc-trip-catalog-api-post-trips",
          "method": "POST",
          "path": "/trips",
          "summary": "Create a new trip definition"
        },
        {
          "unique-id": "svc-trip-catalog-api-get-trips-{trip_id}",
          "method": "GET",
          "path": "/trips/{trip_id}",
          "summary": "Get trip details"
        },
        {
          "unique-id": "svc-trip-catalog-api-patch-trips-{trip_id}",
          "method": "PATCH",
          "path": "/trips/{trip_id}",
          "summary": "Update trip details"
        },
        {
          "unique-id": "svc-trip-catalog-api-get-trips-{trip_id}-schedule",
          "method": "GET",
          "path": "/trips/{trip_id}/schedule",
          "summary": "Get scheduled departures"
        },
        {
          "unique-id": "svc-trip-catalog-api-post-trips-{trip_id}-schedule",
          "method": "POST",
          "path": "/trips/{trip_id}/schedule",
          "summary": "Add a scheduled departure"
        },
        {
          "unique-id": "svc-trip-catalog-api-get-trips-{trip_id}-pricing",
          "method": "GET",
          "path": "/trips/{trip_id}/pricing",
          "summary": "Get pricing tiers"
        },
        {
          "unique-id": "svc-trip-catalog-api-put-trips-{trip_id}-pricing",
          "method": "PUT",
          "path": "/trips/{trip_id}/pricing",
          "summary": "Replace pricing tiers"
        },
        {
          "unique-id": "svc-trip-catalog-api-get-trips-{trip_id}-requirements",
          "method": "GET",
          "path": "/trips/{trip_id}/requirements",
          "summary": "Get trip requirements"
        },
        {
          "unique-id": "svc-trip-catalog-api-get-regions",
          "method": "GET",
          "path": "/regions",
          "summary": "List operating regions"
        },
        {
          "unique-id": "svc-trip-catalog-api-get-activity-types",
          "method": "GET",
          "path": "/activity-types",
          "summary": "List available activity types"
        }
      ],
      "metadata": {
        "domain": "Product Catalog",
        "team": "Product Team"
      }
    },
    {
      "unique-id": "svc-trip-catalog-db",
      "node-type": "database",
      "name": "Trip Catalog Database",
      "description": "PostgreSQL 15 database for svc-trip-catalog (catalog schema)",
      "interfaces": [
        {
          "unique-id": "svc-trip-catalog-db-jdbc",
          "host": "trip-catalog-db.novatrek.internal",
          "port": 27017
        }
      ],
      "metadata": {
        "domain": "Product Catalog",
        "engine": "PostgreSQL 15",
        "schema": "catalog",
        "tables": [
          "trips",
          "trip_schedules",
          "pricing_tiers",
          "requirements",
          "regions",
          "activity_types"
        ]
      }
    },
