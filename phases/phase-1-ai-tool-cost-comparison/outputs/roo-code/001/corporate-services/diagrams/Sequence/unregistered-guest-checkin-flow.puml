@startuml unregistered-guest-checkin-flow

title NTK-10003: Unregistered Guest Self-Service Check-in - Sequence Diagram

skinparam backgroundColor #FEFEFE
skinparam sequenceMessageAlign center

actor "Guest" as guest
participant "Kiosk UI" as kiosk
participant "svc-check-in\n(Orchestrator)" as checkin
participant "Rate Limiter\n(Redis)" as ratelimit
participant "svc-reservations" as reservations
participant "svc-partner-\nintegrations" as partners
participant "svc-guest-profiles" as profiles
participant "svc-safety-\ncompliance" as safety
participant "svc-gear-\ninventory" as gear
participant "Session Manager\n(Redis)" as session

== Step 1: Guest Initiates Self-Service Check-in ==

guest -> kiosk : Selects "Check in with\nConfirmation Code"
kiosk -> kiosk : Display 4-field form\n(last name, confirmation code,\nadventure date, participant count)
guest -> kiosk : Enters verification fields\nand submits
kiosk -> checkin : POST /check-ins/self-service/unregistered\n{last_name, confirmation_code,\nadventure_date, participant_count,\nkiosk_device_id}

== Step 1a: Input Validation and Rate Check ==

checkin -> checkin : Normalize input\n(uppercase code, trim whitespace)
checkin -> ratelimit : Check rate limit\n(5 per kiosk per 15 min)

alt Rate limit exceeded
    ratelimit --> checkin : EXCEEDED
    checkin --> kiosk : 429 Too Many Requests\n{retry_after_seconds}
    kiosk --> guest : "Too many attempts.\nPlease visit service desk."
else Rate limit OK
    ratelimit --> checkin : OK (attempts remaining)
end

== Step 2: Reservation Lookup ==

checkin -> reservations : POST /reservations/search\n{last_name, confirmation_code,\nadventure_date, participant_count}

alt Reservation found
    reservations --> checkin : 200 OK\n{reservation_id, adventure_name,\nbooking_source, participants[]}
else Reservation not found
    reservations --> checkin : 404 Not Found

    == Step 2a: Partner Fallback ==

    checkin -> partners : POST /partner-integrations/verify-booking\n{confirmation_code, last_name}

    alt Partner confirms booking
        partners --> checkin : 200 OK\n{partner_reservation_data}
        checkin -> reservations : POST /reservations\n(sync partner booking)
        reservations --> checkin : 201 Created\n{reservation_id}
    else Partner lookup fails or unavailable
        partners --> checkin : 404 or circuit breaker open
        checkin -> checkin : Add 2-second artificial delay
        checkin --> kiosk : 404 Not Found\n"We couldn't find a matching\nreservation."
        kiosk --> guest : Display error message\nwith staff desk guidance
    end
end

== Step 3: Find or Create Guest Profile ==

checkin -> profiles : GET /guest-profiles\n?reservation_id={id}

alt Profile exists
    profiles --> checkin : 200 OK\n{guest_profile_id, profile_type}
else No profile found
    checkin -> profiles : POST /guest-profiles/temporary\n{last_name, reservation_id}
    profiles --> checkin : 201 Created\n{guest_profile_id, profile_type=TEMPORARY}
end

== Step 4: Parallel Safety and Gear Checks ==

par Safety Compliance Check
    checkin -> safety : GET /safety-compliance/waivers\n?reservation_id={id}
    safety --> checkin : {waiver_complete, waiver_url}
also Gear Assignment Check
    checkin -> gear : GET /gear-inventory/assignments\n?reservation_id={id}
    gear --> checkin : {gear_assigned, gear_items[]}
end

== Step 5: Create Kiosk Session ==

checkin -> session : Create JWT session\n{guest_profile_id, reservation_id,\nkiosk_device_id, expiry=30min}
session --> checkin : session_token (JWT)

== Step 6: Return Aggregated Response ==

checkin --> kiosk : 200 OK\n{session_token, reservation_id,\nguest_profile_id, adventure_name,\ncheck_in_status, participants[]}

kiosk -> kiosk : Transition to standard\ncheck-in flow with\npre-populated data

kiosk --> guest : Display check-in\nconfirmation and\nnext steps

@enduml
