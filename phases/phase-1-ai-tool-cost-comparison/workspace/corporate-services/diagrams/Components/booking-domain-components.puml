@startuml booking-domain-components
' NovaTrek Adventures - Booking Domain Detailed Components
' Internal structure of svc-reservations, svc-trip-catalog, svc-scheduling-orchestrator

title NovaTrek Adventures - Booking Domain Components

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam roundCorner 8
skinparam defaultFontName "Segoe UI"

' ============================================================
' svc-reservations
' ============================================================
package "svc-reservations" #E8F4F8 {
    component "ReservationController" as res_ctrl
    component "ReservationService" as res_svc
    component "ReservationRepository" as res_repo
    component "ReservationEventPublisher" as res_pub
    database "reservations-db" as res_db
}

' ============================================================
' svc-trip-catalog
' ============================================================
package "svc-trip-catalog" #E8F0F8 {
    component "TripCatalogController" as trip_ctrl
    component "TripCatalogService" as trip_svc
    component "TripRepository" as trip_repo
    component "AvailabilityEngine" as trip_avail
    database "trip-catalog-db" as trip_db
}

' ============================================================
' svc-scheduling-orchestrator
' ============================================================
package "svc-scheduling-orchestrator" #E8ECF8 {
    component "ScheduleController" as sched_ctrl
    component "ScheduleOrchestratorService" as sched_svc
    component "ConflictResolver" as sched_conflict
    component "ScheduleRepository" as sched_repo
    component "ScheduleEventPublisher" as sched_pub
    database "scheduling-db" as sched_db
}

' ============================================================
' Kafka Topics
' ============================================================
queue "reservation.created" as topic_res_created
queue "reservation.confirmed" as topic_res_confirmed
queue "schedule.optimized" as topic_sched_optimized

' ============================================================
' Internal Flows - svc-reservations
' ============================================================
res_ctrl --> res_svc
res_svc --> res_repo
res_repo --> res_db
res_svc --> res_pub
res_pub --> topic_res_created
res_pub --> topic_res_confirmed

' ============================================================
' Internal Flows - svc-trip-catalog
' ============================================================
trip_ctrl --> trip_svc
trip_svc --> trip_repo
trip_svc --> trip_avail
trip_repo --> trip_db

' ============================================================
' Internal Flows - svc-scheduling-orchestrator
' ============================================================
sched_ctrl --> sched_svc
sched_svc --> sched_conflict
sched_svc --> sched_repo
sched_repo --> sched_db
sched_svc --> sched_pub
sched_pub --> topic_sched_optimized

' ============================================================
' Inter-Service Communication
' ============================================================
res_svc --> trip_svc : "check availability"
sched_svc --> trip_svc : "trip constraints"

@enduml
