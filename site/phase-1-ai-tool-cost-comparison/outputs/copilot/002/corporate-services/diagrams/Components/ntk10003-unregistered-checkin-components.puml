@startuml ntk10003-unregistered-checkin-components
' NTK-10003: Unregistered Guest Self-Service Check-in
' C4 Container/Component diagram showing service interactions

title NTK-10003 - Unregistered Guest Self-Service Check-in\nComponent Interaction Diagram

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam roundCorner 8
skinparam defaultFontName "Segoe UI"

' Legend
legend right
  |= Color |= Meaning |
  | <#438DD5> | In-scope: Modified for NTK-10003 |
  | <#999999> | Out-of-scope: Existing, no changes |
  | <#FFF3E0> | Infrastructure component |
endlegend

' ============================================================
' External Actor
' ============================================================
actor "Unregistered Guest\n(at kiosk)" as guest

' ============================================================
' In-scope Services (modified for NTK-10003)
' ============================================================
rectangle "svc-check-in [MODIFIED]" as checkin #438DD5 {
    component "ReservationLookupController" as lookup_ctrl #438DD5
    component "ReservationLookupService\n(Orchestrator)" as lookup_svc #438DD5
    component "KioskSessionManager" as session_mgr #438DD5
    component "LookupRateLimiter" as rate_limiter #438DD5
    component "CheckInController\n(existing)" as checkin_ctrl #999999
}

rectangle "svc-reservations [MODIFIED]" as reservations #438DD5 {
    component "ReservationSearchEndpoint\n(NEW: POST /reservations/search)" as res_search #438DD5
    component "ReservationLookupService" as res_lookup #438DD5
}

rectangle "svc-guest-profiles [MODIFIED]" as profiles #438DD5 {
    component "TemporaryProfileEndpoint\n(NEW: POST /guest-profiles/temporary)" as temp_profile #438DD5
    component "ProfileMergeService" as merge_svc #438DD5
}

rectangle "svc-safety-compliance [MODIFIED]" as safety #438DD5 {
    component "WaiverLookupEndpoint\n(EXTENDED: reservation_id query)" as waiver_lookup #438DD5
}

' ============================================================
' Out-of-scope Services (existing, no changes)
' ============================================================
component "svc-gear-inventory" as gear #999999
component "svc-partner-integrations" as partners #999999

' ============================================================
' Infrastructure
' ============================================================
database "Redis\n(session + rate limit)" as redis #FFF3E0
component "Kong API Gateway\n(rate limiting)" as kong #FFF3E0

' ============================================================
' Relationships
' ============================================================
guest --> kong : "POST /check-ins/lookup-reservation\n[HTTPS]"
kong --> lookup_ctrl : "route + gateway rate limit\n[HTTP]"

lookup_ctrl --> rate_limiter : "check application rate limit"
rate_limiter --> redis : "increment/check counter\n[Redis protocol]"

lookup_ctrl --> lookup_svc : "orchestrate verification"

lookup_svc --> res_search : "Step 2: POST /reservations/search\n[REST/JSON, 2s timeout]"
lookup_svc --> partners : "Step 2a: POST /partner-integrations/verify-booking\n[REST/JSON, 30s timeout, circuit breaker]"

lookup_svc --> temp_profile : "Step 3: POST /guest-profiles/temporary\n[REST/JSON, 1s timeout]"

lookup_svc --> waiver_lookup : "Step 4a: GET /waivers?reservation_id=\n[REST/JSON, 3s timeout]"
lookup_svc --> gear : "Step 4b: GET /gear-inventory/assignments?reservation_id=\n[REST/JSON, 3s timeout]"

note right of lookup_svc : "Steps 4a and 4b\nexecute in parallel\n(CompletableFuture.allOf)"

lookup_svc --> session_mgr : "Step 5: create JWT session"
session_mgr --> redis : "store session\n(30-min TTL)\n[Redis protocol]"

res_search --> res_lookup : "composite query:\nlast_name + confirmation_code\n+ adventure_date + participant_count"

@enduml
