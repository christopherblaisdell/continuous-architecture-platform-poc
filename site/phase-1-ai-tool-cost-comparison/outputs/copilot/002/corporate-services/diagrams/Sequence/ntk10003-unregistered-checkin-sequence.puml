@startuml ntk10003-unregistered-checkin-sequence
' NTK-10003: Unregistered Guest Self-Service Check-in
' Full orchestration sequence diagram

title NTK-10003 - Unregistered Guest Self-Service Check-in\nOrchestration Sequence

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequenceParticipant underline

actor "Guest" as Guest
participant "Kiosk UI" as Kiosk
participant "Kong API\nGateway" as Kong
participant "svc-check-in\n(Orchestrator)" as CheckIn
participant "svc-reservations" as Reservations
participant "svc-partner-\nintegrations" as Partners
participant "svc-guest-\nprofiles" as Profiles
participant "svc-safety-\ncompliance" as Safety
participant "svc-gear-\ninventory" as Gear
database "Redis" as Redis

== Guest Initiates Check-in ==

Guest -> Kiosk : Select "Check in with\nConfirmation Code"
Kiosk -> Kiosk : Display four-field\nverification form

Guest -> Kiosk : Enter last_name,\nconfirmation_code,\nadventure_date,\nparticipant_count

Kiosk -> Kong : POST /check-ins/lookup-reservation\n{last_name, confirmation_code,\nadventure_date, participant_count,\nkiosk_device_id}

== Step 1: Gateway Rate Limit ==

Kong -> Kong : Check gateway rate limit\n(5 per kiosk per 15 min)

alt Rate Limit Exceeded (Gateway)
    Kong --> Kiosk : 429 RATE_LIMIT_EXCEEDED
    Kiosk -> Guest : "Too many attempts.\nPlease visit service desk."
else Within Limit
    Kong -> CheckIn : Forward request
end

== Step 1b: Input Validation and Application Rate Limit ==

CheckIn -> CheckIn : Validate input fields\nNormalize confirmation_code\nto uppercase

CheckIn -> Redis : Check app-level rate limit\nfor kiosk_device_id

alt Rate Limit Exceeded (Application)
    CheckIn --> Kiosk : 429 RATE_LIMIT_EXCEEDED
else Within Limit
end

== Step 2: Reservation Lookup ==

CheckIn -> Reservations : POST /reservations/search\n{last_name, confirmation_code,\nadventure_date, participant_count}

alt Reservation Found
    Reservations --> CheckIn : 200 OK\n{reservation_id, adventure_name,\nparticipants[], booking_source}

else Reservation Not Found
    Reservations --> CheckIn : 404 Not Found

    == Step 2a: Partner Fallback ==

    CheckIn -> CheckIn : Extract partner prefix\nfrom confirmation_code\n(EM-, TF-, WP-)

    alt Partner Identified
        CheckIn -> Partners : POST /partner-integrations/\nverify-booking\n{partner_id, confirmation_code,\nlast_name}

        alt Partner Confirms Booking
            Partners --> CheckIn : 200 OK {booking_details}
            CheckIn -> Reservations : POST /reservations\n(create synced reservation)
            Reservations --> CheckIn : 201 Created\n{reservation_id}
        else Partner Booking Not Found
            Partners --> CheckIn : 404 Not Found
            CheckIn -> CheckIn : Apply 2-second\nartificial delay
            CheckIn --> Kiosk : 404 RESERVATION_NOT_FOUND
            Kiosk -> Guest : "We couldn't find a\nmatching reservation.\nVisit service desk."
        end
    else No Partner Prefix
        CheckIn -> CheckIn : Apply 2-second\nartificial delay
        CheckIn --> Kiosk : 404 RESERVATION_NOT_FOUND
        Kiosk -> Guest : Display error message
    end
end

== Step 3: Guest Profile ==

CheckIn -> Profiles : GET /guest-profiles\n?reservation_id={id}

alt Profile Exists
    Profiles --> CheckIn : 200 OK\n{guest_profile_id, profile_type}

else No Profile
    CheckIn -> Profiles : POST /guest-profiles/temporary\n{last_name, reservation_id}
    Profiles --> CheckIn : 201 Created\n{guest_profile_id,\nprofile_type: TEMPORARY}
end

== Step 4: Parallel Status Checks ==

par Safety Compliance Check (3s timeout)
    CheckIn -> Safety : GET /waivers\n?reservation_id={id}

    alt Waiver Service Available
        Safety --> CheckIn : 200 OK\n{waiver_complete, waiver_url}
    else Waiver Service Unavailable
        note right of Safety : Graceful degradation:\nwaiver_complete = null\nguest completes manually
        Safety --> CheckIn : 503 (timeout)
        CheckIn -> CheckIn : Set waiver_complete = null\nLog WARNING
    end

else Gear Assignment Check (3s timeout)
    CheckIn -> Gear : GET /gear-inventory/\nassignments\n?reservation_id={id}

    alt Gear Service Available
        Gear --> CheckIn : 200 OK\n{gear_items[], pickup_location}
    else Gear Service Unavailable
        note right of Gear : Graceful degradation:\ngear_assigned = null\nconfirm at pickup
        Gear --> CheckIn : 503 (timeout)
        CheckIn -> CheckIn : Set gear_assigned = null\nLog WARNING
    end
end

== Step 5: Session Creation ==

CheckIn -> CheckIn : Generate JWT session token\n{guest_profile_id,\nreservation_id,\nkiosk_device_id,\nexpiry: 30 min}

CheckIn -> Redis : Store session\n(key: session_id,\nsecondary: kiosk_device_id,\nTTL: 30 min)

Redis --> CheckIn : OK

CheckIn --> Kiosk : 200 OK\n{session_token, reservation_id,\nguest_profile_id, adventure_name,\ncheck_in_status{waiver, gear},\nparticipants[]}

Kiosk -> Guest : Display check-in summary\nand proceed with\nstandard kiosk flow

@enduml
