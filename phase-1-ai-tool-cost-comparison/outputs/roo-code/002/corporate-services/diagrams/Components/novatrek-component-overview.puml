@startuml novatrek-component-overview
' NovaTrek Adventures - Component Overview
' All microservices grouped by domain with key dependencies
' Updated: NTK-10001 - Added elevation data flow notation

title NovaTrek Adventures - Microservice Component Overview

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam roundCorner 8
skinparam defaultFontName "Segoe UI"
skinparam rectangle {
    BorderColor #2E86AB
    BackgroundColor #FFFFFF
}
skinparam component {
    BackgroundColor #E8F4F8
    BorderColor #2E86AB
}

' ============================================================
' API Gateway
' ============================================================
component "Kong API Gateway" as kong #FFF3E0

' ============================================================
' Booking Domain
' ============================================================
rectangle "Booking Domain" #E8F4F8 {
    component "svc-reservations" as reservations
    component "svc-trip-catalog" as trip_catalog
    component "svc-scheduling-orchestrator" as scheduling
}

' ============================================================
' Guest Domain
' ============================================================
rectangle "Guest Domain" #F0E8F4 {
    component "svc-guest-profiles" as guest_profiles
    component "svc-check-in" as checkin
    component "svc-loyalty-rewards" as loyalty
}

' ============================================================
' Operations Domain
' ============================================================
rectangle "Operations Domain" #E8F4E8 {
    component "svc-gear-inventory" as gear
    component "svc-guide-management" as guides
    component "svc-trail-management" as trails
    note right of trails : "NTK-10001: Now exposes\nelevation_gain_m,\nelevation_loss_m,\nmax_elevation_m,\nmin_elevation_m, and\nelevation_profile[]\nin trail responses\n(v1.2.0)"
    component "svc-safety-compliance" as safety
}

' ============================================================
' Infrastructure Domain
' ============================================================
rectangle "Infrastructure Domain" #F4F0E8 {
    component "svc-payments" as payments
    component "svc-notifications" as notifications
    component "svc-weather" as weather
    component "svc-transport-logistics" as transport
    component "svc-location-services" as location
}

' ============================================================
' Supporting Services
' ============================================================
rectangle "Supporting Services" #F4E8E8 {
    component "svc-media-gallery" as media
    component "svc-analytics" as analytics
    component "svc-partner-integrations" as partners
    component "svc-inventory-procurement" as procurement
}

' ============================================================
' Kafka Event Bus
' ============================================================
queue "Kafka Event Bus" as kafka #FFF8E1

' ============================================================
' API Gateway Routes
' ============================================================
kong --> reservations
kong --> trip_catalog
kong --> guest_profiles
kong --> checkin
kong --> partners

' ============================================================
' Synchronous Dependencies
' ============================================================
reservations --> trip_catalog : "trip availability"
reservations --> guest_profiles : "guest validation"
reservations --> gear : "gear reservation"
reservations --> payments : "payment processing"
checkin --> reservations : "reservation lookup"
checkin --> safety : "waiver verification"
checkin --> gear : "gear assignment"
scheduling --> guides : "guide availability"
scheduling --> trails : "trail conditions\n+ elevation data\n(gain/loss/profile)"
scheduling --> weather : "weather forecast"
scheduling --> trip_catalog : "trip requirements"
loyalty --> guest_profiles : "guest data"
procurement --> gear : "stock levels"
transport --> location : "GPS tracking"
partners --> reservations : "partner bookings"

' ============================================================
' Async Communication via Kafka
' ============================================================
reservations --> kafka : "reservation.created"
checkin --> kafka : "checkin.completed"
payments --> kafka : "payment.processed"
kafka --> notifications : "send alerts"
kafka --> analytics : "event ingestion"
kafka --> loyalty : "points calculation"

@enduml
