@startuml ntk10003-unregistered-checkin-components
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title NTK-10003: Unregistered Guest Self-Service Check-in - Component Diagram

LAYOUT_WITH_LEGEND()

Person(guest, "Unregistered Guest", "Guest without a NovaTrek account\nwho has a valid reservation")

System_Boundary(kiosk_boundary, "Self-Service Kiosk") {
    Component(kiosk_ui, "Kiosk UI", "React/Electron", "Touch-optimized check-in\ninterface with 'Check in\nwith Confirmation Code' flow")
}

System_Boundary(checkin_boundary, "svc-check-in") {
    Component(lookup_controller, "ReservationLookupController", "Spring REST Controller", "POST /check-ins/self-service/unregistered\nInput validation, rate limit check")
    Component(lookup_service, "ReservationLookupService", "Spring Service", "Orchestrates the multi-service\nverification and session flow")
    Component(session_manager, "KioskSessionManager", "Spring Component", "JWT generation, Redis session\nstorage, one-session-per-kiosk")
    Component(rate_limiter, "RateLimitService", "Spring Component + Redis", "5 requests per kiosk per\n15-minute sliding window")
}

System_Boundary(reservations_boundary, "svc-reservations") {
    Component(reservation_search, "ReservationSearchEndpoint", "Spring REST", "POST /reservations/search\nComposite index lookup by\nlast_name + confirmation_code\n+ date + participant_count")
}

System_Boundary(guest_boundary, "svc-guest-profiles") {
    Component(temp_profile, "TemporaryProfileEndpoint", "Spring REST", "POST /guest-profiles/temporary\nCreates TEMPORARY profile\nwith 90-day TTL")
}

System_Boundary(safety_boundary, "svc-safety-compliance") {
    Component(waiver_check, "WaiverLookupEndpoint", "Spring REST", "GET /safety-compliance/waivers\nReturns waiver status and\ndigital signing URL")
}

System_Boundary(partner_boundary, "svc-partner-integrations") {
    Component(partner_verify, "PartnerVerifyEndpoint", "Spring REST", "POST /partner-integrations/verify-booking\nFallback for partner bookings\n(ExploreMore, TrailFinder, WildPass)")
}

Rel(guest, kiosk_ui, "Enters confirmation code,\nlast name, date, count")
Rel(kiosk_ui, lookup_controller, "POST /check-ins/self-service/unregistered", "HTTPS/JSON")
Rel(lookup_controller, rate_limiter, "Check rate limit")
Rel(lookup_controller, lookup_service, "Orchestrate verification")
Rel(lookup_service, reservation_search, "Step 2: Lookup reservation", "HTTPS/JSON")
Rel(lookup_service, partner_verify, "Step 2a: Fallback if not found", "HTTPS/JSON")
Rel(lookup_service, temp_profile, "Step 3: Find/create profile", "HTTPS/JSON")
Rel(lookup_service, waiver_check, "Step 4: Check waiver (parallel)", "HTTPS/JSON")
Rel(lookup_service, session_manager, "Step 5: Create kiosk session")
Rel(session_manager, kiosk_ui, "Returns JWT session token", "HTTPS/JSON")

@enduml
