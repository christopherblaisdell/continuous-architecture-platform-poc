@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

AddRelTag("pci", $lineColor="#DC2626", $textColor="#DC2626", $legendText="PCI Data Flow")

header [[/microservices/ ⬆ All Microservices]]

title svc-payments — Integration Context

Person(app_guest_mobile, "Adventure App", "Mobile App", $link="/applications/app-guest-mobile/#service-dependencies")
Person(web_guest_portal, "Guest Portal", "Web App", $link="/applications/web-guest-portal/#service-dependencies")
Person(web_ops_dashboard, "Operations Dashboard", "Web App", $link="/applications/web-ops-dashboard/#service-dependencies")

System_Boundary(boundary, "NovaTrek Platform") {
    Container(svc_payments, "svc-payments", "Java / Spring Boot", "Payments Service", $link="/microservices/svc-payments/")
    ContainerDb(svc_payments_db, "PostgreSQL 15", "payments schema", "Primary data store", $link="/microservices/svc-payments/#data-store")
    Container(svc_inventory_procurement, "svc-inventory-procurement", "Java / Spring Boot", "Support", $link="/microservices/svc-inventory-procurement/#integration-context")
    Container(svc_loyalty_rewards, "svc-loyalty-rewards", "Java / Spring Boot", "Support", $link="/microservices/svc-loyalty-rewards/#integration-context")
    Container(svc_partner_integrations, "svc-partner-integrations", "Java / Spring Boot", "External", $link="/microservices/svc-partner-integrations/#integration-context")
    Container(svc_reservations, "svc-reservations", "Java / Spring Boot", "Booking", $link="/microservices/svc-reservations/#integration-context")
    Container(svc_notifications, "svc-notifications", "Java / Spring Boot", "Support", $link="/microservices/svc-notifications/#integration-context")
}

System_Ext(Fraud_Detection_API, "Fraud Detection API", "PCI-certified third-party")
System_Ext(Payment_Gateway, "Payment Gateway", "PCI-certified third-party")

Rel(app_guest_mobile, svc_payments, "Uses API", "HTTPS")
Rel(web_guest_portal, svc_payments, "Uses API", "HTTPS")
Rel(web_ops_dashboard, svc_payments, "Uses API", "HTTPS")
Rel(svc_inventory_procurement, svc_payments, "Process PO payment", "HTTPS", $tags="pci")
Rel(svc_loyalty_rewards, svc_payments, "Process reward credit", "HTTPS", $tags="pci")
Rel(svc_partner_integrations, svc_payments, "Process commission", "HTTPS", $tags="pci")
Rel(svc_reservations, svc_payments, "Process deposit payment", "HTTPS", $tags="pci")
Rel(svc_payments, svc_payments_db, "Reads/Writes", "SQL/TCP")
Rel(svc_payments, svc_notifications, "2 calls", "HTTPS")
Rel(svc_payments, Fraud_Detection_API, "Screen transaction", "HTTPS", $tags="pci")
Rel(svc_payments, Payment_Gateway, "Process refund via gateway, Tokenize & route payment", "HTTPS", $tags="pci")

@enduml