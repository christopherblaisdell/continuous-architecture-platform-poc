@startuml svc-scheduling-orchestrator--get-schedule-requests-request_id

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title GET /schedule-requests/{request_id}\nGet schedule request status and result

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-scheduling-orchestrator" as Svc [[/microservices/svc-scheduling-orchestrator/]] #E8F4F8
database "PG + Valkey" as DB #FCE4EC

note over Svc
  [[/services/api/svc-scheduling-orchestrator.html View in Swagger UI]]
end note

Client -> GW : GET /schedule-requests/{request_id}
activate GW #2563eb
GW -> Svc : route request
activate Svc #2563eb

== Database ==

Svc -> DB : SELECT ... WHERE id = ?
activate DB #FCE4EC
DB --> Svc : Row
deactivate DB
note right of DB : Returns 404 if not found

Svc --> GW : 200 OK
deactivate Svc
GW --> Client : 200 OK
deactivate GW

@enduml