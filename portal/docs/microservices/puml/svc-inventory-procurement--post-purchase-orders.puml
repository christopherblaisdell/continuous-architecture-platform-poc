@startuml svc-inventory-procurement--post-purchase-orders

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/microservices/svc-inventory-procurement/#integration-context ⬆ svc-inventory-procurement Integration Context]]

title POST /purchase-orders\nCreate a new purchase order

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-inventory-procurement" as Svc [[/microservices/svc-inventory-procurement/]] #F1F5F9
participant "Gear Inventory" as GI [[/microservices/svc-gear-inventory/]] #CFFAFE
participant "Supplier Procurement Portal" as Supplier [[/actors/#supplier-procurement-portal]] #F3F4F6
participant "Payments Svc" as Pay [[/microservices/svc-payments/]] #FEE2E2
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9
database "PostgreSQL" as DB [[/microservices/svc-inventory-procurement/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-inventory-procurement.html View in Swagger UI]]
end note

Client -> GW : POST /purchase-orders
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> GI : [[/microservices/svc-gear-inventory/#get-gear-items-search-gear-inventory Verify item catalog]]
activate GI #CFFAFE
GI --> Svc : OK
deactivate GI

Svc -> Supplier : Submit purchase order to approved vendor
activate Supplier #F3F4F6
Supplier --> Svc : OK
deactivate Supplier

Svc -[#DC2626]> Pay : [[/microservices/svc-payments/#post-payments-process-a-payment Process PO payment]]
activate Pay #F1F5F9
Pay --[#DC2626]> Svc : OK
deactivate Pay

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FEF9C3
DB --> Svc : Created row
deactivate DB

== Async Events ==

Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Notify procurement team]]

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml