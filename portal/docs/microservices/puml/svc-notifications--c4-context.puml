@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

header [[/microservices/ ⬆ All Microservices]]

title svc-notifications — Integration Context

Person(app_guest_mobile, "Adventure App", "Mobile App", $link="/applications/app-guest-mobile/#service-dependencies")
Person(web_guest_portal, "Guest Portal", "Web App", $link="/applications/web-guest-portal/#service-dependencies")
Person(web_ops_dashboard, "Operations Dashboard", "Web App", $link="/applications/web-ops-dashboard/#service-dependencies")

System_Boundary(boundary, "NovaTrek Platform") {
    Container(svc_notifications, "svc-notifications", "Java / Spring Boot", "Notifications Service", $link="/microservices/svc-notifications/")
    ContainerDb(svc_notifications_db, "PostgreSQL 15 + Valkey 8", "notifications schema", "Primary data store", $link="/microservices/svc-notifications/#data-store")
    Container(svc_check_in, "svc-check-in", "Java / Spring Boot", "Operations", $link="/microservices/svc-check-in/#integration-context")
    Container(svc_emergency_response, "svc-emergency-response", "Java / Spring Boot", "Safety", $link="/microservices/svc-emergency-response/#integration-context")
    Container(svc_inventory_procurement, "svc-inventory-procurement", "Java / Spring Boot", "Support", $link="/microservices/svc-inventory-procurement/#integration-context")
    Container(svc_loyalty_rewards, "svc-loyalty-rewards", "Java / Spring Boot", "Support", $link="/microservices/svc-loyalty-rewards/#integration-context")
    Container(svc_media_gallery, "svc-media-gallery", "Java / Spring Boot", "Support", $link="/microservices/svc-media-gallery/#integration-context")
    Container(svc_partner_integrations, "svc-partner-integrations", "Java / Spring Boot", "External", $link="/microservices/svc-partner-integrations/#integration-context")
    Container(svc_payments, "svc-payments", "Java / Spring Boot", "Support", $link="/microservices/svc-payments/#integration-context")
    Container(svc_reservations, "svc-reservations", "Java / Spring Boot", "Booking", $link="/microservices/svc-reservations/#integration-context")
    Container(svc_safety_compliance, "svc-safety-compliance", "Java / Spring Boot", "Safety", $link="/microservices/svc-safety-compliance/#integration-context")
    Container(svc_scheduling_orchestrator, "svc-scheduling-orchestrator", "Java / Spring Boot", "Operations", $link="/microservices/svc-scheduling-orchestrator/#integration-context")
    Container(svc_trail_management, "svc-trail-management", "Java / Spring Boot", "Product Catalog", $link="/microservices/svc-trail-management/#integration-context")
    Container(svc_transport_logistics, "svc-transport-logistics", "Java / Spring Boot", "Logistics", $link="/microservices/svc-transport-logistics/#integration-context")
    Container(svc_weather, "svc-weather", "Java / Spring Boot", "Support", $link="/microservices/svc-weather/#integration-context")
    Container(svc_wildlife_tracking, "svc-wildlife-tracking", "Java / Spring Boot", "Safety", $link="/microservices/svc-wildlife-tracking/#integration-context")
}

System_Ext(Firebase_Cloud_Messaging, "Firebase Cloud Messaging", "Third-party service", $link="/actors/#firebase-cloud-messaging")
System_Ext(SendGrid_API, "SendGrid API", "Third-party service", $link="/actors/#sendgrid-api")
System_Ext(Twilio_API, "Twilio API", "Third-party service", $link="/actors/#twilio-api")

Rel(app_guest_mobile, svc_notifications, "Uses API", "HTTPS")
Rel(web_guest_portal, svc_notifications, "Uses API", "HTTPS")
Rel(web_ops_dashboard, svc_notifications, "Uses API", "HTTPS")
Rel(svc_check_in, svc_notifications, "Send check-in confirmation", "HTTPS")
Rel(svc_emergency_response, svc_notifications, "2 calls", "HTTPS")
Rel(svc_inventory_procurement, svc_notifications, "Notify procurement team", "HTTPS")
Rel(svc_loyalty_rewards, svc_notifications, "2 calls", "HTTPS")
Rel(svc_media_gallery, svc_notifications, "Send share link", "HTTPS")
Rel(svc_partner_integrations, svc_notifications, "Send partner confirmation", "HTTPS")
Rel(svc_payments, svc_notifications, "2 calls", "HTTPS")
Rel(svc_reservations, svc_notifications, "3 calls", "HTTPS")
Rel(svc_safety_compliance, svc_notifications, "2 calls", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_notifications, "2 calls", "HTTPS")
Rel(svc_trail_management, svc_notifications, "Alert park rangers", "HTTPS")
Rel(svc_transport_logistics, svc_notifications, "Send transport details", "HTTPS")
Rel(svc_weather, svc_notifications, "Distribute severe weather alerts", "HTTPS")
Rel(svc_wildlife_tracking, svc_notifications, "Alert operations staff and active guides", "HTTPS")
Rel(svc_notifications, svc_notifications_db, "Reads/Writes", "SQL/TCP")
Rel(svc_notifications, Firebase_Cloud_Messaging, "Send bulk push notifications, Send push notification", "HTTPS")
Rel(svc_notifications, SendGrid_API, "Deliver bulk emails, Deliver email", "HTTPS")
Rel(svc_notifications, Twilio_API, "Deliver SMS, Deliver bulk SMS", "HTTPS")

' Layout hints: stack peers in columns
Lay_D(svc_check_in, svc_partner_integrations)
Lay_D(svc_emergency_response, svc_payments)
Lay_D(svc_inventory_procurement, svc_reservations)
Lay_D(svc_loyalty_rewards, svc_safety_compliance)
Lay_D(svc_media_gallery, svc_scheduling_orchestrator)
Lay_D(svc_partner_integrations, svc_trail_management)
Lay_D(svc_payments, svc_transport_logistics)
Lay_D(svc_reservations, svc_weather)
Lay_D(svc_safety_compliance, svc_wildlife_tracking)

@enduml