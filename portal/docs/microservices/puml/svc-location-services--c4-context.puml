@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

header [[/microservices/ ⬆ All Microservices]]

title svc-location-services — Integration Context

Person(app_guest_mobile, "Adventure App", "Mobile App", $link="/applications/app-guest-mobile/#service-dependencies")
Person(web_ops_dashboard, "Operations Dashboard", "Web App", $link="/applications/web-ops-dashboard/#service-dependencies")

System_Boundary(boundary, "NovaTrek Platform") {
    Container(svc_location_services, "svc-location-services", "Java / Spring Boot", "Location Services Service", $link="/microservices/svc-location-services/")
    ContainerDb(svc_location_services_db, "PostGIS (PostgreSQL 15)", "locations schema", "Primary data store", $link="/microservices/svc-location-services/#data-store")
    Container(svc_scheduling_orchestrator, "svc-scheduling-orchestrator", "Java / Spring Boot", "Operations", $link="/microservices/svc-scheduling-orchestrator/#integration-context")
    Container(svc_trail_management, "svc-trail-management", "Java / Spring Boot", "Product Catalog", $link="/microservices/svc-trail-management/#integration-context")
    Container(svc_transport_logistics, "svc-transport-logistics", "Java / Spring Boot", "Logistics", $link="/microservices/svc-transport-logistics/#integration-context")
}

System_Ext(Google_Maps_Platform, "Google Maps Platform", "Third-party service", $link="/actors/#google-maps-platform")

Rel(app_guest_mobile, svc_location_services, "Uses API", "HTTPS")
Rel(web_ops_dashboard, svc_location_services, "Uses API", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_location_services, "Check location capacity", "HTTPS")
Rel(svc_trail_management, svc_location_services, "Get trail coordinates", "HTTPS")
Rel(svc_transport_logistics, svc_location_services, "Validate pickup location", "HTTPS")
Rel(svc_location_services, svc_location_services_db, "Reads/Writes", "SQL/TCP")
Rel(svc_location_services, Google_Maps_Platform, "Geocode address", "HTTPS")

@enduml