@startuml svc-trip-catalog--post-trips

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/microservices/svc-trip-catalog/#integration-context ⬆ svc-trip-catalog Integration Context]]

title POST /trips\nCreate a new trip definition

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-trip-catalog" as Svc [[/microservices/svc-trip-catalog/]] #FEF3C7
database "PostgreSQL" as DB [[/microservices/svc-trip-catalog/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-trip-catalog.html#/Trips/createTrip View in Swagger UI]]
end note

Client -> GW : POST /trips
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FEF9C3
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml