@startuml svc-partner-integrations--post-partner-bookings

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title POST /partner-bookings\nExternal partner creates a booking

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-partner-integrations" as Svc [[/microservices/svc-partner-integrations/]] #E8F4F8
participant "Reservations" as Res [[/microservices/svc-reservations/]] #FFF8F0
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-partner-integrations.html#/Partner%20Bookings/createPartnerBooking View in Swagger UI]]
end note

Client -> GW : POST /partner-bookings
activate GW #059669
GW -> Svc : [[/microservices/svc-partner-integrations/#post-partner-bookings-external-partner-creates-a-booking route request]]
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> Res : [[/microservices/svc-reservations/#post-reservations-create-a-new-reservation Create reservation]]
activate Res #DBEAFE
Res --> Svc : OK
deactivate Res

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml