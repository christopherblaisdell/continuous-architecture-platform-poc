@startuml svc-payments--post-payments-payment_id-refund

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/microservices/svc-payments/#integration-context ⬆ svc-payments Integration Context]]

title POST /payments/{payment_id}/refund\nInitiate a refund

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW #DBEAFE
participant "svc-payments" as Svc [[/microservices/svc-payments/]] #E8F4F8
participant "Stripe API" as ExtPay #F5F5F5
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #FFF8F0
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-payments.html#/Refunds/refundPayment View in Swagger UI]]
end note

Client -> GW : POST /payments/{payment_id}/refund
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> ExtPay : Process refund
activate ExtPay #DBEAFE
ExtPay --> Svc : OK
deactivate ExtPay

== Database ==

Svc -> DB : SELECT parent WHERE id = ?
activate DB #FCE4EC
DB --> Svc : Parent row
deactivate DB
note right of DB : 404 if parent not found

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

== Async Events ==

Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send refund confirmation]]

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml