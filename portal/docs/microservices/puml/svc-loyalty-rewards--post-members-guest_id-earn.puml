@startuml svc-loyalty-rewards--post-members-guest_id-earn

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title POST /members/{guest_id}/earn\nAward points to a member

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-loyalty-rewards" as Svc [[/microservices/svc-loyalty-rewards/]] #E8F4F8
participant "Reservations" as Res [[/microservices/svc-reservations/]] #FFF8F0
participant "Guest Profiles" as GP [[/microservices/svc-guest-profiles/]] #FFF8F0
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #FFF8F0
database "Couchbase" as DB #FCE4EC

note over Svc
  [[/services/api/svc-loyalty-rewards.html#/Transactions/earnPoints View in Swagger UI]]
end note

Client -> GW : POST /members/{guest_id}/earn
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details Verify completed booking]]
activate Res #DBEAFE
Res --> Svc : OK
deactivate Res

Svc -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Get member profile]]
activate GP #DBEAFE
GP --> Svc : OK
deactivate GP

== Database ==

Svc -> DB : GET parent document by key
activate DB #FCE4EC
DB --> Svc : Document
deactivate DB
note right of DB : 404 if parent not found

Svc -> DB : INSERT document
activate DB #FCE4EC
DB --> Svc : Document
deactivate DB

== Async Events ==

Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send earn confirmation]]

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml