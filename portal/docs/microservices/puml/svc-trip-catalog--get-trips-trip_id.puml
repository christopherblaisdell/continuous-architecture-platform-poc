@startuml svc-trip-catalog--get-trips-trip_id

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title GET /trips/{trip_id}\nGet trip details

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-trip-catalog" as Svc [[/microservices/svc-trip-catalog/]] #E8F4F8
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-trip-catalog.html#/Trips/getTripById View in Swagger UI]]
end note

Client -> GW : GET /trips/{trip_id}
activate GW #2563eb
GW -> Svc : route request
activate Svc #2563eb

== Database ==

Svc -> DB : SELECT ... WHERE id = ?
activate DB #FCE4EC
DB --> Svc : Row
deactivate DB
note right of DB : Returns 404 if not found

Svc --> GW : 200 OK
deactivate Svc
GW --> Client : 200 OK
deactivate GW

@enduml