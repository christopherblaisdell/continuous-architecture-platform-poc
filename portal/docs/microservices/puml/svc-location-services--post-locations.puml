@startuml svc-location-services--post-locations

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/microservices/svc-location-services/#integration-context ⬆ svc-location-services Integration Context]]

title POST /locations\nCreate a new location

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW #DBEAFE
participant "svc-location-services" as Svc [[/microservices/svc-location-services/]] #E8F4F8
participant "Google Maps Platform" as ExtMap #F5F5F5
database "PostGIS" as DB #FCE4EC

note over Svc
  [[/services/api/svc-location-services.html View in Swagger UI]]
end note

Client -> GW : POST /locations
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> ExtMap : Geocode address
activate ExtMap #DBEAFE
ExtMap --> Svc : OK
deactivate ExtMap

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml