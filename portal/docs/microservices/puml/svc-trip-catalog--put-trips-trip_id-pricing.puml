@startuml svc-trip-catalog--put-trips-trip_id-pricing

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #c77b30
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/microservices/svc-trip-catalog/#integration-context ⬆ svc-trip-catalog Integration Context]]

title PUT /trips/{trip_id}/pricing\nReplace pricing tiers

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW #DBEAFE
participant "svc-trip-catalog" as Svc [[/microservices/svc-trip-catalog/]] #E8F4F8
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-trip-catalog.html#/Pricing/updateTripPricing View in Swagger UI]]
end note

Client -> GW : PUT /trips/{trip_id}/pricing
activate GW #c77b30
GW -> Svc : route request
activate Svc #c77b30

note right of Svc : Validate request body

== Database ==

Svc -> DB : SELECT ... FOR UPDATE
activate DB #FCE4EC
DB --> Svc : Current row
deactivate DB
note right of Svc : Replace mutable fields

Svc -> DB : UPDATE ... SET ...
activate DB #FCE4EC
DB --> Svc : Updated row
deactivate DB

Svc --> GW : 200 OK
deactivate Svc
GW --> Client : 200 OK
deactivate GW

@enduml