@startuml svc-weather--get-weather-forecast

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/microservices/svc-weather/#integration-context ⬆ svc-weather Integration Context]]

title GET /weather/forecast\nGet weather forecast

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #DBEAFE
participant "svc-weather" as Svc [[/microservices/svc-weather/]] #E8F4F8
participant "OpenWeather API" as ExtWx [[/actors/#openweather-api]] #F5F5F5
database "Valkey + PG" as DB [[/microservices/svc-weather/#data-store]] #FCE4EC

note over Svc
  [[/services/api/svc-weather.html#/Weather/getWeatherForecast View in Swagger UI]]
end note

Client -> GW : GET /weather/forecast
activate GW #2563eb
GW -> Svc : route request
activate Svc #2563eb

== Cross-Service Integration ==

Svc -> ExtWx : Fetch multi-day forecast
activate ExtWx #DBEAFE
ExtWx --> Svc : OK
deactivate ExtWx

== Database ==

Svc -> DB : SELECT ... WHERE filters
activate DB #FCE4EC
DB --> Svc : Page of results
deactivate DB

Svc --> GW : 200 OK
deactivate Svc
GW --> Client : 200 OK
deactivate GW

@enduml