@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

header [[/microservices/ ⬆ All Microservices]]

title svc-weather — Integration Context

Person(app_guest_mobile, "Adventure App", "Mobile App", $link="/applications/app-guest-mobile/#service-dependencies")
Person(web_guest_portal, "Guest Portal", "Web App", $link="/applications/web-guest-portal/#service-dependencies")
Person(web_ops_dashboard, "Operations Dashboard", "Web App", $link="/applications/web-ops-dashboard/#service-dependencies")

System_Boundary(boundary, "NovaTrek Platform") {
    Container(svc_weather, "svc-weather", "Java / Spring Boot", "Weather Service", $link="/microservices/svc-weather/")
    ContainerDb(svc_weather_db, "Valkey 8 + PostgreSQL 15", "weather schema", "Primary data store", $link="/microservices/svc-weather/#data-store")
    Container(svc_scheduling_orchestrator, "svc-scheduling-orchestrator", "Java / Spring Boot", "Operations", $link="/microservices/svc-scheduling-orchestrator/#integration-context")
    Container(svc_trail_management, "svc-trail-management", "Java / Spring Boot", "Product Catalog", $link="/microservices/svc-trail-management/#integration-context")
    Container(svc_wildlife_tracking, "svc-wildlife-tracking", "Java / Spring Boot", "Safety", $link="/microservices/svc-wildlife-tracking/#integration-context")
    Container(svc_notifications, "svc-notifications", "Java / Spring Boot", "Support", $link="/microservices/svc-notifications/#integration-context")
}

System_Ext(OpenWeather_API, "OpenWeather API", "Third-party service", $link="/actors/#openweather-api")

Rel(app_guest_mobile, svc_weather, "Uses API", "HTTPS")
Rel(web_guest_portal, svc_weather, "Uses API", "HTTPS")
Rel(web_ops_dashboard, svc_weather, "Uses API", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_weather, "Get forecast", "HTTPS")
Rel(svc_trail_management, svc_weather, "Correlate weather data", "HTTPS")
Rel(svc_wildlife_tracking, svc_weather, "Get current conditions at sighting location", "HTTPS")
Rel(svc_weather, svc_weather_db, "Reads/Writes", "SQL/TCP")
Rel(svc_weather, svc_notifications, "Distribute severe weather alerts", "HTTPS")
Rel(svc_weather, OpenWeather_API, "Fetch active alerts, Fetch current conditions", "HTTPS")

@enduml