@startuml svc-gear-inventory--post-gear-assignments

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/microservices/svc-gear-inventory/#integration-context ⬆ svc-gear-inventory Integration Context]]

title POST /gear-assignments\nAssign gear to a participant

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW #DBEAFE
participant "svc-gear-inventory" as Svc [[/microservices/svc-gear-inventory/]] #E8F4F8
participant "Guest Profiles" as GP [[/microservices/svc-guest-profiles/]] #FFF8F0
participant "Reservations" as Res [[/microservices/svc-reservations/]] #FFF8F0
participant "Safety Compliance" as Safety [[/microservices/svc-safety-compliance/]] #FFF8F0
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-gear-inventory.html#/Gear%20Assignments/createGearAssignment View in Swagger UI]]
end note

Client -> GW : POST /gear-assignments
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Validate guest]]
activate GP #DBEAFE
GP --> Svc : OK
deactivate GP

Svc -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details Verify booking]]
activate Res #DBEAFE
Res --> Svc : OK
deactivate Res

Svc -> Safety : [[/microservices/svc-safety-compliance/#get-waivers-list-waivers-by-guest Check waiver status]]
activate Safety #DBEAFE
Safety --> Svc : OK
deactivate Safety

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml