@startuml svc-inventory-procurement--get-suppliers

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title GET /suppliers\nList all suppliers

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-inventory-procurement" as Svc [[/microservices/svc-inventory-procurement/]] #E8F4F8
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-inventory-procurement.html View in Swagger UI]]
end note

Client -> GW : GET /suppliers
activate GW #2563eb
GW -> Svc : [[/microservices/svc-inventory-procurement/#get-suppliers-list-all-suppliers route request]]
activate Svc #2563eb

== Database ==

Svc -> DB : SELECT ... WHERE filters
activate DB #FCE4EC
DB --> Svc : Page of results
deactivate DB

Svc --> GW : 200 OK
deactivate Svc
GW --> Client : 200 OK
deactivate GW

@enduml