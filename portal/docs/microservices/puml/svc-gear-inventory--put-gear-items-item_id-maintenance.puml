@startuml svc-gear-inventory--put-gear-items-item_id-maintenance

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #c77b30
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title PUT /gear-items/{item_id}/maintenance\nLog a maintenance event

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-gear-inventory" as Svc [[/microservices/svc-gear-inventory/]] #E8F4F8
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-gear-inventory.html#/Maintenance/logMaintenanceEvent View in Swagger UI]]
end note

Client -> GW : PUT /gear-items/{item_id}/maintenance
activate GW #c77b30
GW -> Svc : route request
activate Svc #c77b30

note right of Svc : Validate request body

== Database ==

Svc -> DB : SELECT ... FOR UPDATE
activate DB #FCE4EC
DB --> Svc : Current row
deactivate DB
note right of Svc : Replace mutable fields

Svc -> DB : UPDATE ... SET ...
activate DB #FCE4EC
DB --> Svc : Updated row
deactivate DB

Svc --> GW : 200 OK
deactivate Svc
GW --> Client : 200 OK
deactivate GW

@enduml