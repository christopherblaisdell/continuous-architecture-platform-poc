@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title svc-trail-management — Integration Context

Person(app_guest_mobile, "Adventure App", "Mobile App", $link="/applications/app-guest-mobile/")
Person(web_guest_portal, "Guest Portal", "Web App", $link="/applications/web-guest-portal/")
Person(web_ops_dashboard, "Operations Dashboard", "Web App", $link="/applications/web-ops-dashboard/")

System_Boundary(boundary, "NovaTrek Platform") {
    Container(svc_trail_management, "svc-trail-management", "Java / Spring Boot", "Trail Management Service", $link="/microservices/svc-trail-management/")
    ContainerDb(svc_trail_management_db, "PostGIS (PostgreSQL 15)", "trails schema", "Primary data store", $link="/microservices/svc-trail-management/#data-store")
    Container(svc_scheduling_orchestrator, "svc-scheduling-orchestrator", "Java / Spring Boot", "Operations", $link="/microservices/svc-scheduling-orchestrator/")
    Container(svc_location_services, "svc-location-services", "Java / Spring Boot", "Support", $link="/microservices/svc-location-services/")
    Container(svc_notifications, "svc-notifications", "Java / Spring Boot", "Support", $link="/microservices/svc-notifications/")
    Container(svc_safety_compliance, "svc-safety-compliance", "Java / Spring Boot", "Safety", $link="/microservices/svc-safety-compliance/")
    Container(svc_weather, "svc-weather", "Java / Spring Boot", "Support", $link="/microservices/svc-weather/")
}


Rel(app_guest_mobile, svc_trail_management, "Uses API", "HTTPS")
Rel(web_guest_portal, svc_trail_management, "Uses API", "HTTPS")
Rel(web_ops_dashboard, svc_trail_management, "Uses API", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_trail_management, "Verify trail conditions", "HTTPS")
Rel(svc_trail_management, svc_trail_management_db, "Reads/Writes", "SQL/TCP")
Rel(svc_trail_management, svc_location_services, "Get trail coordinates", "HTTPS")
Rel(svc_trail_management, svc_notifications, "Alert park rangers", "HTTPS")
Rel(svc_trail_management, svc_safety_compliance, "Update trail safety assessment", "HTTPS")
Rel(svc_trail_management, svc_weather, "Correlate weather data", "HTTPS")

@enduml