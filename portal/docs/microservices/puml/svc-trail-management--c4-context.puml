@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

header [[/microservices/ ⬆ All Microservices]]

title svc-trail-management — Integration Context

Person(app_guest_mobile, "Adventure App", "Mobile App", $link="/applications/app-guest-mobile/#service-dependencies")
Person(web_guest_portal, "Guest Portal", "Web App", $link="/applications/web-guest-portal/#service-dependencies")
Person(web_ops_dashboard, "Operations Dashboard", "Web App", $link="/applications/web-ops-dashboard/#service-dependencies")

System_Boundary(boundary, "NovaTrek Platform") {
    Container(svc_trail_management, "svc-trail-management", "Java / Spring Boot", "Trail Management Service", $link="/microservices/svc-trail-management/")
    ContainerDb(svc_trail_management_db, "PostGIS (PostgreSQL 15)", "trails schema", "Primary data store", $link="/microservices/svc-trail-management/#data-store")
    Container(svc_scheduling_orchestrator, "svc-scheduling-orchestrator", "Java / Spring Boot", "Operations", $link="/microservices/svc-scheduling-orchestrator/#integration-context")
    Container(svc_wildlife_tracking, "svc-wildlife-tracking", "Java / Spring Boot", "Safety", $link="/microservices/svc-wildlife-tracking/#integration-context")
    Container(svc_location_services, "svc-location-services", "Java / Spring Boot", "Support", $link="/microservices/svc-location-services/#integration-context")
    Container(svc_notifications, "svc-notifications", "Java / Spring Boot", "Support", $link="/microservices/svc-notifications/#integration-context")
    Container(svc_safety_compliance, "svc-safety-compliance", "Java / Spring Boot", "Safety", $link="/microservices/svc-safety-compliance/#integration-context")
    Container(svc_weather, "svc-weather", "Java / Spring Boot", "Support", $link="/microservices/svc-weather/#integration-context")
}

System_Ext(National_Parks_Permit_API, "National Parks Permit API", "Third-party service", $link="/actors/#national-parks-permit-api")

Rel(app_guest_mobile, svc_trail_management, "Uses API", "HTTPS")
Rel(web_guest_portal, svc_trail_management, "Uses API", "HTTPS")
Rel(web_ops_dashboard, svc_trail_management, "Uses API", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_trail_management, "Verify trail conditions", "HTTPS")
Rel(svc_wildlife_tracking, svc_trail_management, "2 calls", "HTTPS")
Rel(svc_trail_management, svc_trail_management_db, "Reads/Writes", "SQL/TCP")
Rel(svc_trail_management, svc_location_services, "Get trail coordinates", "HTTPS")
Rel(svc_trail_management, svc_notifications, "Alert park rangers", "HTTPS")
Rel(svc_trail_management, svc_safety_compliance, "2 calls", "HTTPS")
Rel(svc_trail_management, svc_weather, "Correlate weather data", "HTTPS")
Rel(svc_trail_management, National_Parks_Permit_API, "Check permit approval status, Submit trail access permit request", "HTTPS")

' Layout hints: stack peers in columns
Lay_D(svc_scheduling_orchestrator, svc_location_services)
Lay_D(svc_wildlife_tracking, svc_notifications)
Lay_D(svc_location_services, svc_safety_compliance)
Lay_D(svc_notifications, svc_weather)

@enduml