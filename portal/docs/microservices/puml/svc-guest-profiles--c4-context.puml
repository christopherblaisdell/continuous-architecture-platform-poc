@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

header [[/microservices/ ⬆ All Microservices]]

title svc-guest-profiles — Integration Context

Person(app_guest_mobile, "Adventure App", "Mobile App", $link="/applications/app-guest-mobile/#service-dependencies")
Person(web_guest_portal, "Guest Portal", "Web App", $link="/applications/web-guest-portal/#service-dependencies")
Person(web_ops_dashboard, "Operations Dashboard", "Web App", $link="/applications/web-ops-dashboard/#service-dependencies")

System_Boundary(boundary, "NovaTrek Platform") {
    Container(svc_guest_profiles, "svc-guest-profiles", "Java / Spring Boot", "Guest Profiles Service", $link="/microservices/svc-guest-profiles/")
    ContainerDb(svc_guest_profiles_db, "PostgreSQL 15", "guests schema", "Primary data store", $link="/microservices/svc-guest-profiles/#data-store")
    Container(svc_check_in, "svc-check-in", "Java / Spring Boot", "Operations", $link="/microservices/svc-check-in/#integration-context")
    Container(svc_gear_inventory, "svc-gear-inventory", "Java / Spring Boot", "Logistics", $link="/microservices/svc-gear-inventory/#integration-context")
    Container(svc_loyalty_rewards, "svc-loyalty-rewards", "Java / Spring Boot", "Support", $link="/microservices/svc-loyalty-rewards/#integration-context")
    Container(svc_partner_integrations, "svc-partner-integrations", "Java / Spring Boot", "External", $link="/microservices/svc-partner-integrations/#integration-context")
    Container(svc_reservations, "svc-reservations", "Java / Spring Boot", "Booking", $link="/microservices/svc-reservations/#integration-context")
    Container(svc_safety_compliance, "svc-safety-compliance", "Java / Spring Boot", "Safety", $link="/microservices/svc-safety-compliance/#integration-context")
    Container(svc_analytics, "svc-analytics", "Java / Spring Boot", "Support", $link="/microservices/svc-analytics/#integration-context")
}

System_Ext(IDVerify_API, "IDVerify API", "Third-party service", $link="/actors/#idverify-api")

Rel(app_guest_mobile, svc_guest_profiles, "Uses API", "HTTPS")
Rel(web_guest_portal, svc_guest_profiles, "Uses API", "HTTPS")
Rel(web_ops_dashboard, svc_guest_profiles, "Uses API", "HTTPS")
Rel(svc_check_in, svc_guest_profiles, "Validate guest identity", "HTTPS")
Rel(svc_gear_inventory, svc_guest_profiles, "Validate guest", "HTTPS")
Rel(svc_loyalty_rewards, svc_guest_profiles, "Get member profile", "HTTPS")
Rel(svc_partner_integrations, svc_guest_profiles, "Validate guest identity", "HTTPS")
Rel(svc_reservations, svc_guest_profiles, "2 calls", "HTTPS")
Rel(svc_safety_compliance, svc_guest_profiles, "2 calls", "HTTPS")
Rel(svc_guest_profiles, svc_guest_profiles_db, "Reads/Writes", "SQL/TCP")
Rel(svc_guest_profiles, svc_analytics, "Get satisfaction scores", "HTTPS")
Rel(svc_guest_profiles, svc_reservations, "Query past bookings", "HTTPS")
Rel(svc_guest_profiles, IDVerify_API, "Verify identity document", "HTTPS")

@enduml