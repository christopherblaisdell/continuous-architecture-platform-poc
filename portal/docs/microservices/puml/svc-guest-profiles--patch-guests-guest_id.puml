@startuml svc-guest-profiles--patch-guests-guest_id

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #7c3aed
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/microservices/svc-guest-profiles/#integration-context ⬆ svc-guest-profiles Integration Context]]

title PATCH /guests/{guest_id}\nUpdate guest profile

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #DBEAFE
participant "svc-guest-profiles" as Svc [[/microservices/svc-guest-profiles/]] #E8F4F8
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-guest-profiles.html#/Guests/updateGuest View in Swagger UI]]
end note

Client -> GW : PATCH /guests/{guest_id}
activate GW #7c3aed
GW -> Svc : route request
activate Svc #7c3aed

note right of Svc : Validate request body

== Database ==

Svc -> DB : SELECT ... FOR UPDATE
activate DB #FCE4EC
DB --> Svc : Current row
deactivate DB
note right of Svc : Merge changed fields only

Svc -> DB : UPDATE ... SET ...
activate DB #FCE4EC
DB --> Svc : Updated row
deactivate DB

Svc --> GW : 200 OK
deactivate Svc
GW --> Client : 200 OK
deactivate GW

@enduml