@startuml svc-check-in--post-check-ins-check_in_id-gear-verification

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title POST /check-ins/{check_in_id}/gear-verification\nVerify gear has been picked up and fitted

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-check-in" as Svc [[/microservices/svc-check-in/]] #E8F4F8
participant "Gear Inventory" as Gear [[/microservices/svc-gear-inventory/]] #FFF8F0
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-check-in.html#/Check-Ins/verifyGear View in Swagger UI]]
end note

Client -> GW : POST /check-ins/{check_in_id}/gear-verification
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> Gear : [[/microservices/svc-gear-inventory/ Verify gear assignment]]
activate Gear #DBEAFE
Gear --> Svc : OK
deactivate Gear

== Database ==

Svc -> DB : SELECT parent WHERE id = ?
activate DB #FCE4EC
DB --> Svc : Parent row
deactivate DB
note right of DB : 404 if parent not found

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml