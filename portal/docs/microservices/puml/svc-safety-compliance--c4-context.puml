@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

header [[/microservices/ ⬆ All Microservices]]

title svc-safety-compliance — Integration Context

Person(app_guest_mobile, "Adventure App", "Mobile App", $link="/applications/app-guest-mobile/#service-dependencies")
Person(web_guest_portal, "Guest Portal", "Web App", $link="/applications/web-guest-portal/#service-dependencies")
Person(web_ops_dashboard, "Operations Dashboard", "Web App", $link="/applications/web-ops-dashboard/#service-dependencies")

System_Boundary(boundary, "NovaTrek Platform") {
    Container(svc_safety_compliance, "svc-safety-compliance", "Java / Spring Boot", "Safety Compliance Service", $link="/microservices/svc-safety-compliance/")
    ContainerDb(svc_safety_compliance_db, "PostgreSQL 15", "safety schema", "Primary data store", $link="/microservices/svc-safety-compliance/#data-store")
    Container(svc_check_in, "svc-check-in", "Java / Spring Boot", "Operations", $link="/microservices/svc-check-in/#integration-context")
    Container(svc_emergency_response, "svc-emergency-response", "Java / Spring Boot", "Safety", $link="/microservices/svc-emergency-response/#integration-context")
    Container(svc_gear_inventory, "svc-gear-inventory", "Java / Spring Boot", "Logistics", $link="/microservices/svc-gear-inventory/#integration-context")
    Container(svc_trail_management, "svc-trail-management", "Java / Spring Boot", "Product Catalog", $link="/microservices/svc-trail-management/#integration-context")
    Container(svc_wildlife_tracking, "svc-wildlife-tracking", "Java / Spring Boot", "Safety", $link="/microservices/svc-wildlife-tracking/#integration-context")
    Container(svc_guest_profiles, "svc-guest-profiles", "Java / Spring Boot", "Guest Identity", $link="/microservices/svc-guest-profiles/#integration-context")
    Container(svc_guide_management, "svc-guide-management", "Java / Spring Boot", "Guide Management", $link="/microservices/svc-guide-management/#integration-context")
    Container(svc_notifications, "svc-notifications", "Java / Spring Boot", "Support", $link="/microservices/svc-notifications/#integration-context")
}

System_Ext(DocuSign_API, "DocuSign API", "Third-party service", $link="/actors/#docusign-api")

Rel(app_guest_mobile, svc_safety_compliance, "Uses API", "HTTPS")
Rel(web_guest_portal, svc_safety_compliance, "Uses API", "HTTPS")
Rel(web_ops_dashboard, svc_safety_compliance, "Uses API", "HTTPS")
Rel(svc_check_in, svc_safety_compliance, "2 calls", "HTTPS")
Rel(svc_emergency_response, svc_safety_compliance, "Log emergency as safety incident", "HTTPS")
Rel(svc_gear_inventory, svc_safety_compliance, "Check waiver status", "HTTPS")
Rel(svc_trail_management, svc_safety_compliance, "Update trail safety assessment", "HTTPS")
Rel(svc_wildlife_tracking, svc_safety_compliance, "Log wildlife alert as compliance record", "HTTPS")
Rel(svc_safety_compliance, svc_safety_compliance_db, "Reads/Writes", "SQL/TCP")
Rel(svc_safety_compliance, svc_guest_profiles, "2 calls", "HTTPS")
Rel(svc_safety_compliance, svc_guide_management, "Get assigned guide", "HTTPS")
Rel(svc_safety_compliance, svc_notifications, "2 calls", "HTTPS")
Rel(svc_safety_compliance, DocuSign_API, "Verify digital signature", "HTTPS")

@enduml