@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

AddRelTag("pci", $lineColor="#DC2626", $textColor="#DC2626", $legendText="PCI Data Flow")

header [[/microservices/ ⬆ All Microservices]]

title svc-partner-integrations — Integration Context

Person(web_ops_dashboard, "Operations Dashboard", "Web App", $link="/applications/web-ops-dashboard/#service-dependencies")

System_Boundary(boundary, "NovaTrek Platform") {
    Container(svc_partner_integrations, "svc-partner-integrations", "Java / Spring Boot", "Partner Integrations Service", $link="/microservices/svc-partner-integrations/")
    ContainerDb(svc_partner_integrations_db, "PostgreSQL 15", "partners schema", "Primary data store", $link="/microservices/svc-partner-integrations/#data-store")
    Container(svc_guest_profiles, "svc-guest-profiles", "Java / Spring Boot", "Guest Identity", $link="/microservices/svc-guest-profiles/#integration-context")
    Container(svc_notifications, "svc-notifications", "Java / Spring Boot", "Support", $link="/microservices/svc-notifications/#integration-context")
    Container(svc_payments, "svc-payments", "Java / Spring Boot", "Support", $link="/microservices/svc-payments/#integration-context")
    Container(svc_reservations, "svc-reservations", "Java / Spring Boot", "Booking", $link="/microservices/svc-reservations/#integration-context")
    Container(svc_trip_catalog, "svc-trip-catalog", "Java / Spring Boot", "Product Catalog", $link="/microservices/svc-trip-catalog/#integration-context")
}


Rel(web_ops_dashboard, svc_partner_integrations, "Uses API", "HTTPS")
Rel(svc_partner_integrations, svc_partner_integrations_db, "Reads/Writes", "SQL/TCP")
Rel(svc_partner_integrations, svc_guest_profiles, "Validate guest identity", "HTTPS")
Rel(svc_partner_integrations, svc_notifications, "Send partner confirmation", "HTTPS")
Rel(svc_partner_integrations, svc_payments, "Process commission", "HTTPS", $tags="pci")
Rel(svc_partner_integrations, svc_reservations, "2 calls", "HTTPS")
Rel(svc_partner_integrations, svc_trip_catalog, "Check trip availability", "HTTPS")

' Layout hints: stack peers in columns
Lay_D(svc_guest_profiles, svc_payments)
Lay_D(svc_notifications, svc_reservations)
Lay_D(svc_payments, svc_trip_catalog)

@enduml