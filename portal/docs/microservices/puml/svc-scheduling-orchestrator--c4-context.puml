@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

header [[/microservices/ ⬆ All Microservices]]

title svc-scheduling-orchestrator — Integration Context

Person(app_guest_mobile, "Adventure App", "Mobile App", $link="/applications/app-guest-mobile/#service-dependencies")
Person(web_ops_dashboard, "Operations Dashboard", "Web App", $link="/applications/web-ops-dashboard/#service-dependencies")

System_Boundary(boundary, "NovaTrek Platform") {
    Container(svc_scheduling_orchestrator, "svc-scheduling-orchestrator", "Java / Spring Boot", "Scheduling Orchestrator Service", $link="/microservices/svc-scheduling-orchestrator/")
    ContainerDb(svc_scheduling_orchestrator_db, "PostgreSQL 15 + Valkey 8", "scheduling schema", "Primary data store", $link="/microservices/svc-scheduling-orchestrator/#data-store")
    Container(svc_wildlife_tracking, "svc-wildlife-tracking", "Java / Spring Boot", "Safety", $link="/microservices/svc-wildlife-tracking/#integration-context")
    Container(svc_analytics, "svc-analytics", "Java / Spring Boot", "Support", $link="/microservices/svc-analytics/#integration-context")
    Container(svc_guide_management, "svc-guide-management", "Java / Spring Boot", "Guide Management", $link="/microservices/svc-guide-management/#integration-context")
    Container(svc_location_services, "svc-location-services", "Java / Spring Boot", "Support", $link="/microservices/svc-location-services/#integration-context")
    Container(svc_notifications, "svc-notifications", "Java / Spring Boot", "Support", $link="/microservices/svc-notifications/#integration-context")
    Container(svc_trail_management, "svc-trail-management", "Java / Spring Boot", "Product Catalog", $link="/microservices/svc-trail-management/#integration-context")
    Container(svc_trip_catalog, "svc-trip-catalog", "Java / Spring Boot", "Product Catalog", $link="/microservices/svc-trip-catalog/#integration-context")
    Container(svc_weather, "svc-weather", "Java / Spring Boot", "Support", $link="/microservices/svc-weather/#integration-context")
}


Rel(app_guest_mobile, svc_scheduling_orchestrator, "Uses API", "HTTPS")
Rel(web_ops_dashboard, svc_scheduling_orchestrator, "Uses API", "HTTPS")
Rel(svc_wildlife_tracking, svc_scheduling_orchestrator, "Check for affected scheduled trips", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_scheduling_orchestrator_db, "Reads/Writes", "SQL/TCP")
Rel(svc_scheduling_orchestrator, svc_analytics, "Log optimization metrics", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_guide_management, "3 calls", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_location_services, "Check location capacity", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_notifications, "2 calls", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_trail_management, "Verify trail conditions", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_trip_catalog, "2 calls", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_weather, "Get forecast", "HTTPS")

' Layout hints: stack peers in columns
Lay_D(svc_wildlife_tracking, svc_location_services)
Lay_D(svc_analytics, svc_notifications)
Lay_D(svc_guide_management, svc_trail_management)
Lay_D(svc_location_services, svc_trip_catalog)
Lay_D(svc_notifications, svc_weather)

@enduml