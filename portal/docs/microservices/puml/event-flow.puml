@startuml
!theme plain
top to bottom direction
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Inter
skinparam defaultFontSize 12
skinparam roundCorner 8
skinparam componentStyle rectangle
title NovaTrek Event Flow

rectangle "Producers" {
  component "svc-check-in" as p_svc_check_in [[/microservices/svc-check-in/]] #2563eb
  component "svc-emergency-response" as p_svc_emergency_response [[/microservices/svc-emergency-response/]] #dc2626
  component "svc-guest-profiles" as p_svc_guest_profiles [[/microservices/svc-guest-profiles/]] #7c3aed
  component "svc-payments" as p_svc_payments [[/microservices/svc-payments/]] #64748b
  component "svc-reservations" as p_svc_reservations [[/microservices/svc-reservations/]] #059669
  component "svc-safety-compliance" as p_svc_safety_compliance [[/microservices/svc-safety-compliance/]] #dc2626
  component "svc-scheduling-orchestrator" as p_svc_scheduling_orchestrator [[/microservices/svc-scheduling-orchestrator/]] #2563eb
  component "svc-wildlife-tracking" as p_svc_wildlife_tracking [[/microservices/svc-wildlife-tracking/]] #dc2626
}

queue "Kafka Event Bus" as kafka #F0E6FF

rectangle "Consumers" {
  component "svc-analytics" as c_svc_analytics [[/microservices/svc-analytics/]] #64748b
  component "svc-guide-management" as c_svc_guide_management [[/microservices/svc-guide-management/]] #4f46e5
  component "svc-loyalty-rewards" as c_svc_loyalty_rewards [[/microservices/svc-loyalty-rewards/]] #64748b
  component "svc-notifications" as c_svc_notifications [[/microservices/svc-notifications/]] #64748b
  component "svc-reservations" as c_svc_reservations [[/microservices/svc-reservations/]] #059669
  component "svc-safety-compliance" as c_svc_safety_compliance [[/microservices/svc-safety-compliance/]] #dc2626
  component "svc-scheduling-orchestrator" as c_svc_scheduling_orchestrator [[/microservices/svc-scheduling-orchestrator/]] #2563eb
  component "svc-trail-management" as c_svc_trail_management [[/microservices/svc-trail-management/]] #d97706
}

' Grid layout for p_* elements
Lay_D(p_svc_check_in, p_svc_reservations)
Lay_D(p_svc_emergency_response, p_svc_safety_compliance)
Lay_D(p_svc_guest_profiles, p_svc_scheduling_orchestrator)
Lay_D(p_svc_payments, p_svc_wildlife_tracking)

' Grid layout for c_* elements
Lay_D(c_svc_analytics, c_svc_reservations)
Lay_D(c_svc_guide_management, c_svc_safety_compliance)
Lay_D(c_svc_loyalty_rewards, c_svc_scheduling_orchestrator)
Lay_D(c_svc_notifications, c_svc_trail_management)

p_svc_check_in --> kafka : checkin.completed
p_svc_emergency_response --> kafka : emergency.triggered
p_svc_guest_profiles --> kafka : guest.registered
p_svc_safety_compliance --> kafka : incident.reported
p_svc_payments --> kafka : payment.processed
p_svc_reservations --> kafka : reservation.created
p_svc_reservations --> kafka : reservation.status_changed
p_svc_scheduling_orchestrator --> kafka : schedule.published
p_svc_wildlife_tracking --> kafka : wildlife_alert.issued

kafka --> c_svc_analytics : checkin.completed
kafka --> c_svc_notifications : checkin.completed
kafka --> c_svc_notifications : emergency.triggered
kafka --> c_svc_scheduling_orchestrator : emergency.triggered
kafka --> c_svc_safety_compliance : emergency.triggered
kafka --> c_svc_analytics : emergency.triggered
kafka --> c_svc_loyalty_rewards : guest.registered
kafka --> c_svc_analytics : guest.registered
kafka --> c_svc_notifications : incident.reported
kafka --> c_svc_analytics : incident.reported
kafka --> c_svc_reservations : payment.processed
kafka --> c_svc_notifications : payment.processed
kafka --> c_svc_scheduling_orchestrator : reservation.created
kafka --> c_svc_analytics : reservation.created
kafka --> c_svc_notifications : reservation.status_changed
kafka --> c_svc_analytics : reservation.status_changed
kafka --> c_svc_guide_management : schedule.published
kafka --> c_svc_notifications : schedule.published
kafka --> c_svc_notifications : wildlife_alert.issued
kafka --> c_svc_scheduling_orchestrator : wildlife_alert.issued
kafka --> c_svc_trail_management : wildlife_alert.issued
kafka --> c_svc_analytics : wildlife_alert.issued

@enduml