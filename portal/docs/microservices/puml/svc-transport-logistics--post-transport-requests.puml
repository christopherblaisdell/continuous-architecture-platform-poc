@startuml svc-transport-logistics--post-transport-requests

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/microservices/svc-transport-logistics/#integration-context ⬆ svc-transport-logistics Integration Context]]

title POST /transport-requests\nRequest transport for a reservation

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-transport-logistics" as Svc [[/microservices/svc-transport-logistics/]] #CFFAFE
participant "Reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "Location Svc" as LS [[/microservices/svc-location-services/]] #F1F5F9
participant "Google Maps Platform" as ExtMap [[/actors/#google-maps-platform]] #F3F4F6
participant "Fleet GPS Tracking API" as FleetGPS [[/actors/#fleet-gps-tracking-api]] #F3F4F6
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9
database "PostgreSQL" as DB [[/microservices/svc-transport-logistics/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-transport-logistics.html View in Swagger UI]]
end note

Client -> GW : POST /transport-requests
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details Get booking details]]
activate Res #D1FAE5
Res --> Svc : OK
deactivate Res

Svc -> LS : [[/microservices/svc-location-services/#get-locationslocation_id-get-location-details Validate pickup location]]
activate LS #F1F5F9
LS --> Svc : OK
deactivate LS

Svc -> ExtMap : Calculate optimal route
activate ExtMap #F3F4F6
ExtMap --> Svc : OK
deactivate ExtMap

Svc -> FleetGPS : Get real-time vehicle location and ETA
activate FleetGPS #F3F4F6
FleetGPS --> Svc : OK
deactivate FleetGPS

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FEF9C3
DB --> Svc : Created row
deactivate DB

== Async Events ==

Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send transport details]]

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml