@startuml svc-transport-logistics--post-transport-requests

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title POST /transport-requests\nRequest transport for a reservation

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-transport-logistics" as Svc [[/microservices/svc-transport-logistics/]] #E8F4F8
participant "Location Svc" as LS [[/microservices/svc-location-services/]] #FFF8F0
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-transport-logistics.html View in Swagger UI]]
end note

Client -> GW : POST /transport-requests
activate GW #059669
GW -> Svc : [[/microservices/svc-transport-logistics/#post-transport-requests-request-transport-for-a-reservation route request]]
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> LS : [[/microservices/svc-location-services/#get-locationslocation_id-get-location-details Validate pickup location]]
activate LS #DBEAFE
LS --> Svc : OK
deactivate LS

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml