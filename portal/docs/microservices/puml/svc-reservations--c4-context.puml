@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title svc-reservations — Integration Context

Person(app_guest_mobile, "Adventure App", "Mobile App")
Person(web_guest_portal, "Guest Portal", "Web App")
Person(web_ops_dashboard, "Operations Dashboard", "Web App")

System_Boundary(boundary, "NovaTrek Platform") {
    Container(svc_reservations, "svc-reservations", "Java / Spring Boot", "Reservations Service")
    ContainerDb(svc_reservations_db, "PostgreSQL 15", "reservations schema", "Primary data store")
    Container(svc_check_in, "svc-check-in", "Java / Spring Boot", "Operations")
    Container(svc_gear_inventory, "svc-gear-inventory", "Java / Spring Boot", "Logistics")
    Container(svc_guest_profiles, "svc-guest-profiles", "Java / Spring Boot", "Guest Identity")
    Container(svc_loyalty_rewards, "svc-loyalty-rewards", "Java / Spring Boot", "Support")
    Container(svc_partner_integrations, "svc-partner-integrations", "Java / Spring Boot", "External")
    Container(svc_transport_logistics, "svc-transport-logistics", "Java / Spring Boot", "Logistics")
    Container(svc_notifications, "svc-notifications", "Java / Spring Boot", "Support")
    Container(svc_payments, "svc-payments", "Java / Spring Boot", "Support")
    Container(svc_trip_catalog, "svc-trip-catalog", "Java / Spring Boot", "Product Catalog")
}


Rel(app_guest_mobile, svc_reservations, "Uses API", "HTTPS")
Rel(web_guest_portal, svc_reservations, "Uses API", "HTTPS")
Rel(web_ops_dashboard, svc_reservations, "Uses API", "HTTPS")
Rel(svc_check_in, svc_reservations, "Verify reservation exists", "HTTPS")
Rel(svc_gear_inventory, svc_reservations, "Verify booking", "HTTPS")
Rel(svc_guest_profiles, svc_reservations, "Query past bookings", "HTTPS")
Rel(svc_loyalty_rewards, svc_reservations, "Verify completed booking", "HTTPS")
Rel(svc_partner_integrations, svc_reservations, "2 calls", "HTTPS")
Rel(svc_transport_logistics, svc_reservations, "Get booking details", "HTTPS")
Rel(svc_reservations, svc_reservations_db, "Reads/Writes", "SQL/TCP")
Rel(svc_reservations, svc_guest_profiles, "2 calls", "HTTPS")
Rel(svc_reservations, svc_notifications, "2 calls", "HTTPS")
Rel(svc_reservations, svc_payments, "Process deposit payment", "HTTPS")
Rel(svc_reservations, svc_trip_catalog, "2 calls", "HTTPS")

@enduml