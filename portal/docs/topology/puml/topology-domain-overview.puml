@startuml
!include <c4/C4_Context>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

AddRelTag("kafka", $lineStyle=DashedLine(), $lineColor="#7c3aed", $textColor="#7c3aed", $legendText="Kafka Events")

title NovaTrek Adventures — Domain Overview

System(Booking, "Booking", "1 service", $link="/topology/domain-views/#booking", $tags="domain")
System(External, "External", "1 service", $link="/topology/domain-views/#external", $tags="domain")
System(Guest_Identity, "Guest Identity", "1 service", $link="/topology/domain-views/#guest-identity", $tags="domain")
