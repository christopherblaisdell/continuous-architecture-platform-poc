Rel(External, Support, "1 REST + 1 events", "HTTPS / Kafka")
Rel(Guest_Identity, Booking, "1 REST calls", "HTTPS")
Rel(Guest_Identity, Support, "1 REST + 2 events", "HTTPS / Kafka")
Rel(Logistics, Booking, "2 REST calls", "HTTPS")
Rel(Logistics, Guest_Identity, "1 REST calls", "HTTPS")
Rel(Logistics, Safety, "1 REST calls", "HTTPS")
Rel(Logistics, Support, "1 REST + 1 events", "HTTPS / Kafka")
