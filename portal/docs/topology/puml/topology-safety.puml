@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

AddRelTag("kafka", $lineStyle=DashedLine(), $lineColor="#7c3aed", $textColor="#7c3aed", $legendText="Kafka Events")

header [[/topology/system-map/ ⬆ System Map]]
title Safety — Service Topology

System_Boundary(Safety, "Safety") {
    Container(svc_emergency_response, "svc-emergency-response", "Java / Spring Boot", "Emergency Response", $link="/microservices/svc-emergency-response/#integration-context")
    Container(svc_safety_compliance, "svc-safety-compliance", "Java / Spring Boot", "Safety Compliance", $link="/microservices/svc-safety-compliance/#integration-context")
    Container(svc_wildlife_tracking, "svc-wildlife-tracking", "Java / Spring Boot", "Wildlife Tracking", $link="/microservices/svc-wildlife-tracking/#integration-context")
}

System_Boundary(Guest_Identity, "Guest Identity") {
    Container(svc_guest_profiles, "svc-guest-profiles", "Java / Spring Boot", "Guest Profiles", $link="/microservices/svc-guest-profiles/#integration-context")
}

System_Boundary(Guide_Management, "Guide Management") {
    Container(svc_guide_management, "svc-guide-management", "Java / Spring Boot", "Guide Management", $link="/microservices/svc-guide-management/#integration-context")
}

System_Boundary(Logistics, "Logistics") {
    Container(svc_gear_inventory, "svc-gear-inventory", "Java / Spring Boot", "Gear Inventory", $link="/microservices/svc-gear-inventory/#integration-context")
}

System_Boundary(Operations, "Operations") {
    Container(svc_check_in, "svc-check-in", "Java / Spring Boot", "Check In", $link="/microservices/svc-check-in/#integration-context")
    Container(svc_scheduling_orchestrator, "svc-scheduling-orchestrator", "Java / Spring Boot", "Scheduling Orchestrator", $link="/microservices/svc-scheduling-orchestrator/#integration-context")
}

System_Boundary(Product_Catalog, "Product Catalog") {
    Container(svc_trail_management, "svc-trail-management", "Java / Spring Boot", "Trail Management", $link="/microservices/svc-trail-management/#integration-context")
}

System_Boundary(Support, "Support") {
    Container(svc_analytics, "svc-analytics", "Java / Spring Boot", "Analytics", $link="/microservices/svc-analytics/#integration-context")
    Container(svc_location_services, "svc-location-services", "Java / Spring Boot", "Location Services", $link="/microservices/svc-location-services/#integration-context")
    Container(svc_notifications, "svc-notifications", "Java / Spring Boot", "Notifications", $link="/microservices/svc-notifications/#integration-context")
    Container(svc_weather, "svc-weather", "Java / Spring Boot", "Weather", $link="/microservices/svc-weather/#integration-context")
}

Rel(svc_check_in, svc_safety_compliance, "API call", "HTTPS")
Rel(svc_emergency_response, svc_guest_profiles, "API call", "HTTPS")
Rel(svc_emergency_response, svc_guide_management, "API call", "HTTPS")
Rel(svc_emergency_response, svc_location_services, "API call", "HTTPS")
Rel(svc_emergency_response, svc_notifications, "API call", "HTTPS")
Rel(svc_emergency_response, svc_safety_compliance, "API call", "HTTPS")
Rel(svc_gear_inventory, svc_safety_compliance, "API call", "HTTPS")
Rel(svc_safety_compliance, svc_guest_profiles, "API call", "HTTPS")
Rel(svc_safety_compliance, svc_guide_management, "API call", "HTTPS")
Rel(svc_safety_compliance, svc_notifications, "API call", "HTTPS")
Rel(svc_trail_management, svc_safety_compliance, "API call", "HTTPS")
Rel(svc_wildlife_tracking, svc_notifications, "API call", "HTTPS")
Rel(svc_wildlife_tracking, svc_safety_compliance, "API call", "HTTPS")
Rel(svc_wildlife_tracking, svc_scheduling_orchestrator, "API call", "HTTPS")
Rel(svc_wildlife_tracking, svc_trail_management, "API call", "HTTPS")
Rel(svc_wildlife_tracking, svc_weather, "API call", "HTTPS")
Rel(svc_emergency_response, svc_analytics, "Event", "Kafka", $tags="kafka")
Rel(svc_emergency_response, svc_notifications, "Event", "Kafka", $tags="kafka")
Rel(svc_emergency_response, svc_safety_compliance, "Event", "Kafka", $tags="kafka")
Rel(svc_emergency_response, svc_scheduling_orchestrator, "Event", "Kafka", $tags="kafka")
Rel(svc_safety_compliance, svc_analytics, "Event", "Kafka", $tags="kafka")
Rel(svc_safety_compliance, svc_notifications, "Event", "Kafka", $tags="kafka")
Rel(svc_wildlife_tracking, svc_analytics, "Event", "Kafka", $tags="kafka")
Rel(svc_wildlife_tracking, svc_notifications, "Event", "Kafka", $tags="kafka")
Rel(svc_wildlife_tracking, svc_scheduling_orchestrator, "Event", "Kafka", $tags="kafka")
Rel(svc_wildlife_tracking, svc_trail_management, "Event", "Kafka", $tags="kafka")
Lay_D(svc_check_in, svc_scheduling_orchestrator)
Lay_D(svc_analytics, svc_location_services)
Lay_D(svc_location_services, svc_notifications)
Lay_D(svc_notifications, svc_weather)

@enduml