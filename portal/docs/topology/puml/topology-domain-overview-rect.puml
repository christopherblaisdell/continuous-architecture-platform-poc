@startuml
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam roundCorner 12
skinparam arrowThickness 1.5
skinparam rectangle {
    BorderThickness 2
    FontStyle bold
    FontSize 13
}

title NovaTrek Adventures — Domain Overview

rectangle "External\n<size:11>1 service</size>" as External #F3E8FF;line:#9333ea;text:#6b21a8
rectangle "Guest Identity\n<size:11>1 service</size>" as Guest_Identity #EDE9FE;line:#7c3aed;text:#5b21b6
rectangle "Booking\n<size:11>1 service</size>" as Booking #D1FAE5;line:#059669;text:#065f46
rectangle "Product Catalog\n<size:11>2 services</size>" as Product_Catalog #FEF3C7;line:#d97706;text:#92400e
rectangle "Operations\n<size:11>2 services</size>" as Operations #DBEAFE;line:#2563eb;text:#1e40af
rectangle "Safety\n<size:11>3 services</size>" as Safety #FEE2E2;line:#dc2626;text:#991b1b
rectangle "Guide Mgmt\n<size:11>1 service</size>" as Guide_Management #E0E7FF;line:#4f46e5;text:#3730a3
rectangle "Logistics\n<size:11>2 services</size>" as Logistics #CFFAFE;line:#0891b2;text:#155e75
rectangle "Support\n<size:11>9 services</size>" as Support #F1F5F9;line:#64748b;text:#334155

External --> Booking : 1
External --> Guest_Identity : 1
Booking --> Guest_Identity : 2
Booking --> Product_Catalog : 1
Operations --> Product_Catalog : 3
Operations --> Safety : 4
Operations --> Guest_Identity : 1
Operations --> Guide_Management : 2
Operations --> Support : 6
Safety --> Support : 8
Booking --> Support : 6
Guest_Identity --> Support : 5
Product_Catalog --> Support : 3

External -[#white,norank]-> Product_Catalog
Guest_Identity -[#white,norank]-> Operations
Booking -[#white,norank]-> Safety
Product_Catalog -[#white,norank]-> Guide_Management
Operations -[#white,norank]-> Logistics
Safety -[#white,norank]-> Support

@enduml
