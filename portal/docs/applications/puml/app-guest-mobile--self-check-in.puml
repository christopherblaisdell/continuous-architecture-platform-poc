@startuml app-guest-mobile--self-check-in

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/app-guest-mobile/#service-dependencies ⬆ NovaTrek Adventure App Service Dependencies]]

title Self Check-In\nNovaTrek Adventure App

actor "Guest" as User [[/actors/#guest]]
participant "Mobile App" as App [[/applications/app-guest-mobile/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "svc-guest-profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE
participant "svc-safety-compliance" as SC [[/microservices/svc-safety-compliance/]] #FEE2E2
participant "svc-check-in" as CI [[/microservices/svc-check-in/]] #DBEAFE
participant "svc-gear-inventory" as GI [[/microservices/svc-gear-inventory/]] #CFFAFE

User -> App : Open Self Check-In
activate App #059669
App -> GW : API request
activate GW #059669

== Backend Integration ==

GW -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details Lookup reservation by QR]]
activate Res #D1FAE5
Res --> GW : OK
deactivate Res

GW -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Verify guest identity]]
activate GP #EDE9FE
GP --> GW : OK
deactivate GP

GW -> SC : [[/microservices/svc-safety-compliance/#get-waivers-list-waivers-by-guest Validate waiver status]]
activate SC #FEE2E2
SC --> GW : OK
deactivate SC

GW -> CI : [[/microservices/svc-check-in/#post-check-ins-initiate-check-in-for-a-participant Create check-in record]]
activate CI #DBEAFE
CI --> GW : OK
deactivate CI

GW -> GI : [[/microservices/svc-gear-inventory/#get-gear-assignmentsassignment_id-get-gear-assignment-details Confirm gear assignment]]
activate GI #CFFAFE
GI --> GW : OK
deactivate GI

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml