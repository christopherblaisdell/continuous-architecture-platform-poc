@startuml web-guest-portal--booking-flow

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/web-guest-portal/#service-dependencies ⬆ NovaTrek Guest Portal Service Dependencies]]

title Booking Flow\nNovaTrek Guest Portal

actor "Guest" as User [[/actors/#guest]]
participant "Browser" as App [[/applications/web-guest-portal/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-trip-catalog" as TC [[/microservices/svc-trip-catalog/]] #FEF3C7
participant "svc-guest-profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE
participant "svc-reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "svc-payments" as Pay [[/microservices/svc-payments/]] #F1F5F9
participant "Stripe API" as Stripe #F3F4F6

User -> App : Open Booking Flow
activate App #2563eb
App -> GW : API request
activate GW #2563eb

== Backend Integration ==

GW -> TC : [[/microservices/svc-trip-catalog/#get-tripstrip_id-get-trip-details Check trip availability]]
activate TC #FEF3C7
TC --> GW : OK
deactivate TC

GW -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Get guest profile]]
activate GP #EDE9FE
GP --> GW : OK
deactivate GP

GW -> Res : [[/microservices/svc-reservations/#post-reservations-create-a-new-reservation Create reservation]]
activate Res #D1FAE5
Res --> GW : OK
deactivate Res

GW -> Pay : [[/microservices/svc-payments/#post-payments-process-a-payment Process payment]]
activate Pay #F1F5F9
Pay --> GW : OK
deactivate Pay

GW -> Stripe : Charge card
activate Stripe #F3F4F6
Stripe --> GW : OK
deactivate Stripe

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml