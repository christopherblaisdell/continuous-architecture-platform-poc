@startuml web-guest-portal--booking-flow

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/applications/web-guest-portal/#service-dependencies ⬆ NovaTrek Guest Portal Service Dependencies]]

title Booking Flow\nNovaTrek Guest Portal

actor "Guest" as User [[/applications/web-guest-portal/]]
participant "Browser" as App [[/applications/web-guest-portal/]] #DBEAFE
participant "API Gateway" as GW #DBEAFE
participant "svc-trip-catalog" as TC [[/microservices/svc-trip-catalog/]] #E8F4F8
participant "svc-guest-profiles" as GP [[/microservices/svc-guest-profiles/]] #E8F4F8
participant "svc-reservations" as Res [[/microservices/svc-reservations/]] #E8F4F8
participant "svc-payments" as Pay [[/microservices/svc-payments/]] #E8F4F8
participant "Stripe API" as Stripe #F5F5F5

User -> App : Open Booking Flow
activate App #2563eb
App -> GW : API request
activate GW #2563eb

== Backend Integration ==

GW -> TC : [[/microservices/svc-trip-catalog/#get-tripstrip_id-get-trip-details Check trip availability]]
activate TC #DBEAFE
TC --> GW : OK
deactivate TC

GW -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Get guest profile]]
activate GP #DBEAFE
GP --> GW : OK
deactivate GP

GW -> Res : [[/microservices/svc-reservations/#post-reservations-create-a-new-reservation Create reservation]]
activate Res #DBEAFE
Res --> GW : OK
deactivate Res

GW -> Pay : [[/microservices/svc-payments/#post-payments-process-a-payment Process payment]]
activate Pay #DBEAFE
Pay --> GW : OK
deactivate Pay

GW -> Stripe : Charge card
activate Stripe #DBEAFE
Stripe --> GW : OK
deactivate Stripe

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml