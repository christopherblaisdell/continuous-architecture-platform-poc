@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

header [[/applications/ ⬆ All Applications]]

title app-guest-mobile — Service Dependencies

Person(user, "Guest", "NovaTrek customer", $link="/actors/#guest")

Container(app_guest_mobile, "NovaTrek Adventure App", "React Native 0.74", "Mobile application", $link="/applications/app-guest-mobile/")

System_Boundary(platform, "NovaTrek Platform") {
    Container(domain_Booking, "Booking\n(1 services)", "Java / Spring Boot", "reservations", $link="/microservices/")
    Container(domain_Guest_Identity, "Guest Identity\n(1 services)", "Java / Spring Boot", "guest-profiles", $link="/microservices/")
    Container(domain_Logistics, "Logistics\n(1 services)", "Java / Spring Boot", "gear-inventory", $link="/microservices/")
    Container(domain_Operations, "Operations\n(2 services)", "Java / Spring Boot", "check-in, scheduling-orchestrator", $link="/microservices/")
    Container(domain_Product_Catalog, "Product Catalog\n(2 services)", "Java / Spring Boot", "trail-management, trip-catalog", $link="/microservices/")
    Container(domain_Safety, "Safety\n(1 services)", "Java / Spring Boot", "safety-compliance", $link="/microservices/")
    Container(domain_Support, "Support\n(6 services)", "Java / Spring Boot", "location-services, loyalty-rewards, media-gallery, notifications, payments, weather", $link="/microservices/")
}

System_Ext(Google_Maps_Platform, "Google Maps Platform", "Third-party service")
System_Ext(Object_Store, "Object Store", "Third-party service")
System_Ext(OpenWeather_API, "OpenWeather API", "Third-party service")

Rel(user, app_guest_mobile, "Uses", "HTTPS")
Rel(app_guest_mobile, domain_Booking, "3 screens", "REST/HTTPS")
Rel(app_guest_mobile, domain_Guest_Identity, "2 screens", "REST/HTTPS")
Rel(app_guest_mobile, domain_Logistics, "2 screens", "REST/HTTPS")
Rel(app_guest_mobile, domain_Operations, "3 screens", "REST/HTTPS")
Rel(app_guest_mobile, domain_Product_Catalog, "3 screens", "REST/HTTPS")
Rel(app_guest_mobile, domain_Safety, "1 screen", "REST/HTTPS")
Rel(app_guest_mobile, domain_Support, "8 screens", "REST/HTTPS")
Rel(app_guest_mobile, Google_Maps_Platform, "Uses", "HTTPS")
Rel(app_guest_mobile, Object_Store, "Uses", "HTTPS")
Rel(app_guest_mobile, OpenWeather_API, "Uses", "HTTPS")

@enduml