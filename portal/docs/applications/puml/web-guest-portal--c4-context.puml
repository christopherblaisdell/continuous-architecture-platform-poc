@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

header [[/applications/ ⬆ All Applications]]

title web-guest-portal — Service Dependencies

Person(user, "Guest", "NovaTrek customer", $link="/actors/#guest")

Container(web_guest_portal, "NovaTrek Guest Portal", "React 18", "Web application", $link="/applications/web-guest-portal/")

System_Boundary(platform, "NovaTrek Platform") {
    Container(domain_Booking, "Booking\n(1 services)", "Java / Spring Boot", "reservations", $link="/microservices/")
    Container(domain_Guest_Identity, "Guest Identity\n(1 services)", "Java / Spring Boot", "guest-profiles", $link="/microservices/")
    Container(domain_Product_Catalog, "Product Catalog\n(2 services)", "Java / Spring Boot", "trail-management, trip-catalog", $link="/microservices/")
    Container(domain_Safety, "Safety\n(1 services)", "Java / Spring Boot", "safety-compliance", $link="/microservices/")
    Container(domain_Support, "Support\n(5 services)", "Java / Spring Boot", "loyalty-rewards, media-gallery, notifications, payments, weather", $link="/microservices/")
}

System_Ext(DocuSign_API, "DocuSign API", "Third-party service")
System_Ext(Stripe_API, "Stripe API", "Third-party service")

Rel(user, web_guest_portal, "Uses", "HTTPS")
Rel(web_guest_portal, domain_Booking, "4 screens", "REST/HTTPS")
Rel(web_guest_portal, domain_Guest_Identity, "4 screens", "REST/HTTPS")
Rel(web_guest_portal, domain_Product_Catalog, "3 screens", "REST/HTTPS")
Rel(web_guest_portal, domain_Safety, "1 screen", "REST/HTTPS")
Rel(web_guest_portal, domain_Support, "10 screens", "REST/HTTPS")
Rel(web_guest_portal, DocuSign_API, "Uses", "HTTPS")
Rel(web_guest_portal, Stripe_API, "Uses", "HTTPS")

@enduml