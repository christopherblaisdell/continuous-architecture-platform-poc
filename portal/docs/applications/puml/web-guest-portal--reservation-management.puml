@startuml web-guest-portal--reservation-management

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/web-guest-portal/#service-dependencies ⬆ NovaTrek Guest Portal Service Dependencies]]

title Reservation Management\nNovaTrek Guest Portal

actor "Guest" as User [[/actors/#guest]]
participant "Browser" as App [[/applications/web-guest-portal/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "svc-payments" as Pay [[/microservices/svc-payments/]] #F1F5F9
participant "svc-notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9

User -> App : Open Reservation Management
activate App #2563eb
App -> GW : API request
activate GW #2563eb

== Backend Integration ==

GW -> Res : [[/microservices/svc-reservations/#get-reservations-search-reservations List reservations]]
activate Res #D1FAE5
Res --> GW : OK
deactivate Res

GW -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details Get reservation details]]
activate Res #D1FAE5
Res --> GW : OK
deactivate Res

GW -> Res : [[/microservices/svc-reservations/#put-reservationsreservation_idstatus-transition-reservation-status Update reservation status]]
activate Res #D1FAE5
Res --> GW : OK
deactivate Res

GW -> Pay : [[/microservices/svc-payments/#post-paymentspayment_idrefund-initiate-a-refund Process refund]]
activate Pay #F1F5F9
Pay --> GW : OK
deactivate Pay

GW ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send cancellation notice]]
activate Ntfy #F1F5F9
Ntfy -->> GW : OK
deactivate Ntfy

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml