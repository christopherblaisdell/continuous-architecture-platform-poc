@startuml web-ops-dashboard--daily-schedule-board

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #dc2626
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title Daily Schedule Board\nNovaTrek Operations Dashboard

actor "Guest" as User
participant "Browser" as App #DBEAFE
participant "API Gateway" as GW #DBEAFE
participant "svc-scheduling-orchestrator" as SO [[/microservices/svc-scheduling-orchestrator/]] #E8F4F8
participant "svc-guide-management" as GM [[/microservices/svc-guide-management/]] #E8F4F8
participant "svc-weather" as WX [[/microservices/svc-weather/]] #E8F4F8
participant "svc-trail-management" as TM [[/microservices/svc-trail-management/]] #E8F4F8
participant "svc-location-services" as LS [[/microservices/svc-location-services/]] #E8F4F8

User -> App : Open Daily Schedule Board
activate App #dc2626
App -> GW : API request
activate GW #dc2626

== Backend Integration ==

GW -> SO : [[/microservices/svc-scheduling-orchestrator/ Get daily schedules]]
activate SO #DBEAFE
SO --> GW : OK
deactivate SO

GW -> GM : [[/microservices/svc-guide-management/#get-guidesavailable-find-available-guides-for-a-date-activity-and-region Get available guides]]
activate GM #DBEAFE
GM --> GW : OK
deactivate GM

GW -> WX : [[/microservices/svc-weather/#get-weatherforecast-get-weather-forecast Get weather forecast]]
activate WX #DBEAFE
WX --> GW : OK
deactivate WX

GW -> TM : [[/microservices/svc-trail-management/#get-trailstrail_idconditions-get-current-trail-conditions Get trail conditions]]
activate TM #DBEAFE
TM --> GW : OK
deactivate TM

GW -> LS : [[/microservices/svc-location-services/#get-locationslocation_idcapacity-get-current-capacity-utilization Get location capacity]]
activate LS #DBEAFE
LS --> GW : OK
deactivate LS

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml