@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

header [[/applications/ ⬆ All Applications]]

title web-ops-dashboard — Service Dependencies

Person(user, "Guest", "NovaTrek customer", $link="/actors/#guest")

Container(web_ops_dashboard, "NovaTrek Operations Dashboard", "Angular 17", "Web application", $link="/applications/web-ops-dashboard/")

System_Boundary(platform, "NovaTrek Platform") {
    Container(domain_Booking, "Booking\n(1 services)", "Java / Spring Boot", "reservations", $link="/microservices/")
    Container(domain_External, "External\n(1 services)", "Java / Spring Boot", "partner-integrations", $link="/microservices/")
    Container(domain_Guest_Identity, "Guest Identity\n(1 services)", "Java / Spring Boot", "guest-profiles", $link="/microservices/")
    Container(domain_Guide_Management, "Guide Management\n(1 services)", "Java / Spring Boot", "guide-management", $link="/microservices/")
    Container(domain_Logistics, "Logistics\n(2 services)", "Java / Spring Boot", "gear-inventory, transport-logistics", $link="/microservices/")
    Container(domain_Operations, "Operations\n(2 services)", "Java / Spring Boot", "check-in, scheduling-orchestrator", $link="/microservices/")
    Container(domain_Product_Catalog, "Product Catalog\n(1 services)", "Java / Spring Boot", "trail-management", $link="/microservices/")
    Container(domain_Safety, "Safety\n(1 services)", "Java / Spring Boot", "safety-compliance", $link="/microservices/")
    Container(domain_Support, "Support\n(6 services)", "Java / Spring Boot", "analytics, inventory-procurement, location-services, notifications, payments, weather", $link="/microservices/")
}

System_Ext(Google_Maps_Platform, "Google Maps Platform", "Third-party service")
System_Ext(Snowflake_Data_Cloud, "Snowflake Data Cloud", "Third-party service")

Rel(user, web_ops_dashboard, "Uses", "HTTPS")
Rel(web_ops_dashboard, domain_Booking, "4 screens", "REST/HTTPS")
Rel(web_ops_dashboard, domain_External, "1 screen", "REST/HTTPS")
Rel(web_ops_dashboard, domain_Guest_Identity, "2 screens", "REST/HTTPS")
Rel(web_ops_dashboard, domain_Guide_Management, "3 screens", "REST/HTTPS")
Rel(web_ops_dashboard, domain_Logistics, "3 screens", "REST/HTTPS")
Rel(web_ops_dashboard, domain_Operations, "3 screens", "REST/HTTPS")
Rel(web_ops_dashboard, domain_Product_Catalog, "2 screens", "REST/HTTPS")
Rel(web_ops_dashboard, domain_Safety, "2 screens", "REST/HTTPS")
Rel(web_ops_dashboard, domain_Support, "8 screens", "REST/HTTPS")
Rel(web_ops_dashboard, Google_Maps_Platform, "Uses", "HTTPS")
Rel(web_ops_dashboard, Snowflake_Data_Cloud, "Uses", "HTTPS")

@enduml