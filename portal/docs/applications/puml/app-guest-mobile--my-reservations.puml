@startuml app-guest-mobile--my-reservations

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/app-guest-mobile/#service-dependencies ⬆ NovaTrek Adventure App Service Dependencies]]

title My Reservations\nNovaTrek Adventure App

actor "Guest" as User [[/actors/#guest]]
participant "Mobile App" as App [[/applications/app-guest-mobile/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "svc-trip-catalog" as TC [[/microservices/svc-trip-catalog/]] #FEF3C7
participant "svc-payments" as Pay [[/microservices/svc-payments/]] #F1F5F9

User -> App : Open My Reservations
activate App #059669
App -> GW : API request
activate GW #059669

== Backend Integration ==

GW -> Res : [[/microservices/svc-reservations/#get-reservations-search-reservations List my reservations]]
activate Res #D1FAE5
Res --> GW : OK
deactivate Res

GW -> TC : [[/microservices/svc-trip-catalog/#get-tripstrip_id-get-trip-details Get trip details]]
activate TC #FEF3C7
TC --> GW : OK
deactivate TC

GW -> Pay : [[/microservices/svc-payments/#get-paymentspayment_id-retrieve-payment-details Get payment details]]
activate Pay #F1F5F9
Pay --> GW : OK
deactivate Pay

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml