@startuml app-guest-mobile--photo-upload

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/app-guest-mobile/#service-dependencies ⬆ NovaTrek Adventure App Service Dependencies]]

title Photo Upload\nNovaTrek Adventure App

actor "Guest" as User [[/actors/#guest]]
participant "Mobile App" as App [[/applications/app-guest-mobile/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-media-gallery" as MG [[/microservices/svc-media-gallery/]] #F1F5F9
participant "Object Store" as S3 #F3F4F6
participant "Google Maps Platform" as GM #F3F4F6
participant "svc-notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9

User -> App : Open Photo Upload
activate App #059669
App -> GW : API request
activate GW #059669

== Backend Integration ==

GW -> MG : [[/microservices/svc-media-gallery/#post-media-upload-a-media-item Upload photo]]
activate MG #F1F5F9
MG --> GW : OK
deactivate MG

GW -> S3 : Store binary file
activate S3 #F3F4F6
S3 --> GW : OK
deactivate S3

GW -> GM : Reverse geocode GPS
activate GM #F3F4F6
GM --> GW : OK
deactivate GM

GW -> MG : [[/microservices/svc-media-gallery/#post-mediamedia_idshare-create-a-shareable-link-for-a-media-item Create share link]]
activate MG #F1F5F9
MG --> GW : OK
deactivate MG

GW ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send share notification]]
activate Ntfy #F1F5F9
Ntfy -->> GW : OK
deactivate Ntfy

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml