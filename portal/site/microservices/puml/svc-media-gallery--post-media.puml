@startuml svc-media-gallery--post-media

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/microservices/svc-media-gallery/#integration-context ⬆ svc-media-gallery Integration Context]]

title POST /media\nUpload a media item

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-media-gallery" as Svc [[/microservices/svc-media-gallery/]] #E8F4F8
participant "Object Store" as S3 #F5F5F5
participant "Google Maps Platform" as ExtMap #F5F5F5
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-media-gallery.html#/Media/uploadMedia View in Swagger UI]]
end note

Client -> GW : POST /media
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> S3 : Upload binary file
activate S3 #DBEAFE
S3 --> Svc : OK
deactivate S3

Svc -> ExtMap : Reverse geocode GPS metadata
activate ExtMap #DBEAFE
ExtMap --> Svc : OK
deactivate ExtMap

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml