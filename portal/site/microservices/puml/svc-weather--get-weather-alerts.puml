@startuml svc-weather--get-weather-alerts

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title GET /weather/alerts\nGet active weather alerts for a region

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-weather" as Svc [[/microservices/svc-weather/]] #E8F4F8
participant "Weather API" as ExtWx #F5F5F5
database "Redis + PG" as DB #FCE4EC

note over Svc
  [[/services/api/svc-weather.html#/Alerts/getWeatherAlerts View in Swagger UI]]
end note

Client -> GW : GET /weather/alerts
activate GW #2563eb
GW -> Svc : [[/microservices/svc-weather/#get-weatheralerts-get-active-weather-alerts-for-a-region route request]]
activate Svc #2563eb

== Cross-Service Integration ==

Svc -> ExtWx : Fetch active alerts
activate ExtWx #DBEAFE
ExtWx --> Svc : OK
deactivate ExtWx

== Database ==

Svc -> DB : SELECT ... WHERE filters
activate DB #FCE4EC
DB --> Svc : Page of results
deactivate DB

Svc --> GW : 200 OK
deactivate Svc
GW --> Client : 200 OK
deactivate GW

@enduml