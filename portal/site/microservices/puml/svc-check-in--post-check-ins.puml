@startuml svc-check-in--post-check-ins

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title POST /check-ins\nInitiate check-in for a participant

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-check-in" as Svc [[/microservices/svc-check-in/]] #E8F4F8
participant "Reservations" as Res [[/microservices/svc-reservations/]] #FFF8F0
participant "Safety Compliance" as Safety [[/microservices/svc-safety-compliance/]] #FFF8F0
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-check-in.html#/Check-Ins/createCheckIn View in Swagger UI]]
end note

Client -> GW : POST /check-ins
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details Verify reservation exists]]
activate Res #DBEAFE
Res --> Svc : OK
deactivate Res

Svc -> Safety : [[/microservices/svc-safety-compliance/#get-waivers-list-waivers-by-guest Validate active waiver]]
activate Safety #DBEAFE
Safety --> Svc : OK
deactivate Safety

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml