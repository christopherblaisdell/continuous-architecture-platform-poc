@startuml svc-transport-logistics--post-transport-requests

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/microservices/svc-transport-logistics/#integration-context ⬆ svc-transport-logistics Integration Context]]

title POST /transport-requests\nRequest transport for a reservation

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #DBEAFE
participant "svc-transport-logistics" as Svc [[/microservices/svc-transport-logistics/]] #E8F4F8
participant "Reservations" as Res [[/microservices/svc-reservations/]] #FFF8F0
participant "Location Svc" as LS [[/microservices/svc-location-services/]] #FFF8F0
participant "Google Maps Platform" as ExtMap [[/actors/#google-maps-platform]] #F5F5F5
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #FFF8F0
database "PostgreSQL" as DB [[/microservices/svc-transport-logistics/#data-store]] #FCE4EC

note over Svc
  [[/services/api/svc-transport-logistics.html View in Swagger UI]]
end note

Client -> GW : POST /transport-requests
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details Get booking details]]
activate Res #DBEAFE
Res --> Svc : OK
deactivate Res

Svc -> LS : [[/microservices/svc-location-services/#get-locationslocation_id-get-location-details Validate pickup location]]
activate LS #DBEAFE
LS --> Svc : OK
deactivate LS

Svc -> ExtMap : Calculate optimal route
activate ExtMap #DBEAFE
ExtMap --> Svc : OK
deactivate ExtMap

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

== Async Events ==

Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send transport details]]

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml