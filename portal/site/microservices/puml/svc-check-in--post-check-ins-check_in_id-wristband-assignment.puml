@startuml svc-check-in--post-check-ins-check_in_id-wristband-assignment

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title POST /check-ins/{check_in_id}/wristband-assignment\nAssign RFID wristband to checked-in participant

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-check-in" as Svc [[/microservices/svc-check-in/]] #E8F4F8
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-check-in.html#/Check-Ins/assignWristband View in Swagger UI]]
end note

Client -> GW : POST /check-ins/{check_in_id}/wristband-assignment
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Database ==

Svc -> DB : SELECT parent WHERE id = ?
activate DB #FCE4EC
DB --> Svc : Parent row
deactivate DB
note right of DB : 404 if parent not found

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml