@startuml svc-notifications--post-notifications-bulk

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title POST /notifications/bulk\nSend bulk notifications

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-notifications" as Svc [[/microservices/svc-notifications/]] #E8F4F8
participant "Email/SMS Provider" as ExtMsg #F5F5F5
database "PG + Redis" as DB #FCE4EC

note over Svc
  [[/services/api/svc-notifications.html#/Notifications/sendBulkNotifications View in Swagger UI]]
end note

Client -> GW : POST /notifications/bulk
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

== Async Events ==

Svc ->> ExtMsg : Deliver bulk messages

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml