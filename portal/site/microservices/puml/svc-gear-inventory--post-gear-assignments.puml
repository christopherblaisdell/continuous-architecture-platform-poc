@startuml svc-gear-inventory--post-gear-assignments

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/microservices/svc-gear-inventory/#integration-context ⬆ svc-gear-inventory Integration Context]]

title POST /gear-assignments\nAssign gear to a participant

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-gear-inventory" as Svc [[/microservices/svc-gear-inventory/]] #CFFAFE
participant "Guest Profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE
participant "Reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "Safety Compliance" as Safety [[/microservices/svc-safety-compliance/]] #FEE2E2
database "PostgreSQL" as DB [[/microservices/svc-gear-inventory/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-gear-inventory.html#/Gear%20Assignments/createGearAssignment View in Swagger UI]]
end note

Client -> GW : POST /gear-assignments
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Validate guest]]
activate GP #EDE9FE
GP --> Svc : OK
deactivate GP

Svc -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details Verify booking]]
activate Res #D1FAE5
Res --> Svc : OK
deactivate Res

Svc -> Safety : [[/microservices/svc-safety-compliance/#get-waivers-list-waivers-by-guest Check waiver status]]
activate Safety #FEE2E2
Safety --> Svc : OK
deactivate Safety

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FEF9C3
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml