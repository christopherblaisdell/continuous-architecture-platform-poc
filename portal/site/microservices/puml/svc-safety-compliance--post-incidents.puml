@startuml svc-safety-compliance--post-incidents

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/microservices/svc-safety-compliance/#integration-context ⬆ svc-safety-compliance Integration Context]]

title POST /incidents\nFile an incident report

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-safety-compliance" as Svc [[/microservices/svc-safety-compliance/]] #FEE2E2
participant "Guest Profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE
participant "Guide Mgmt" as GM [[/microservices/svc-guide-management/]] #E0E7FF
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9
database "PostgreSQL" as DB [[/microservices/svc-safety-compliance/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-safety-compliance.html#/Incidents/createIncident View in Swagger UI]]
end note

Client -> GW : POST /incidents
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Get guest contact info]]
activate GP #EDE9FE
GP --> Svc : OK
deactivate GP

Svc -> GM : [[/microservices/svc-guide-management/#get-guidesguide_id-get-guide-by-id Get assigned guide]]
activate GM #E0E7FF
GM --> Svc : OK
deactivate GM

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FEF9C3
DB --> Svc : Created row
deactivate DB

== Async Events ==

Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send safety alert]]

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml