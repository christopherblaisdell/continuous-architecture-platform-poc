@startuml svc-reservations--delete-reservations-reservation_id

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #dc2626
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/microservices/svc-reservations/#integration-context ⬆ svc-reservations Integration Context]]

title DELETE /reservations/{reservation_id}\nCancel a reservation

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-reservations" as Svc [[/microservices/svc-reservations/]] #D1FAE5
database "PostgreSQL" as DB [[/microservices/svc-reservations/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-reservations.html#/Reservations/cancelReservation View in Swagger UI]]
end note

Client -> GW : DELETE /reservations/{reservation_id}
activate GW #dc2626
GW -> Svc : route request
activate Svc #dc2626

== Database ==

Svc -> DB : SELECT ... WHERE id = ?
activate DB #FEF9C3
DB --> Svc : Row
deactivate DB
note right of DB : Returns 404 if not found

Svc -> DB : DELETE FROM ... WHERE id = ?
activate DB #FEF9C3
DB --> Svc : OK
deactivate DB

Svc --> GW : 204 No Content
deactivate Svc
GW --> Client : 204 No Content
deactivate GW

@enduml