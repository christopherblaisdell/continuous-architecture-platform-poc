@startuml svc-payments--get-payments-payment_id

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/microservices/svc-payments/#integration-context ⬆ svc-payments Integration Context]]

title GET /payments/{payment_id}\nRetrieve payment details

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-payments" as Svc [[/microservices/svc-payments/]] #FEE2E2
database "PostgreSQL" as DB [[/microservices/svc-payments/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-payments.html#/Payments/getPayment View in Swagger UI]]
end note

Client -> GW : GET /payments/{payment_id}
activate GW #2563eb
GW -> Svc : route request
activate Svc #2563eb

== Database ==

Svc -> DB : SELECT ... WHERE id = ?
activate DB #FEF9C3
DB --> Svc : Row
deactivate DB
note right of DB : Returns 404 if not found

Svc --> GW : 200 OK
deactivate Svc
GW --> Client : 200 OK
deactivate GW

@enduml