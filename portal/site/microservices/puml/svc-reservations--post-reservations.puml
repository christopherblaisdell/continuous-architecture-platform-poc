@startuml svc-reservations--post-reservations

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/microservices/svc-reservations/#integration-context ⬆ svc-reservations Integration Context]]

title POST /reservations\nCreate a new reservation

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-reservations" as Svc [[/microservices/svc-reservations/]] #D1FAE5
participant "Guest Profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE
participant "Trip Catalog" as TC [[/microservices/svc-trip-catalog/]] #FEF3C7
participant "Payments Svc" as Pay [[/microservices/svc-payments/]] #FEE2E2
queue "Kafka" as Kafka [[/actors/#event-bus]] #F5F3FF
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9
database "PostgreSQL" as DB [[/microservices/svc-reservations/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-reservations.html#/Reservations/createReservation View in Swagger UI]]
end note

Client -> GW : POST /reservations
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Validate guest identity]]
activate GP #EDE9FE
GP --> Svc : OK
deactivate GP

Svc -> TC : [[/microservices/svc-trip-catalog/#get-tripstrip_id-get-trip-details Check trip availability]]
activate TC #FEF3C7
TC --> Svc : OK
deactivate TC

Svc -[#DC2626]> Pay : [[/microservices/svc-payments/#post-payments-process-a-payment Process deposit payment]]
activate Pay #F1F5F9
Pay --[#DC2626]> Svc : OK
deactivate Pay

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FEF9C3
DB --> Svc : Created row
deactivate DB

== Async Events ==

Svc ->> Kafka : [[/events/#reservationcreated reservation.created]]
Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send booking confirmation]]

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml