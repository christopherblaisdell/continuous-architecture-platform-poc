@startuml svc-partner-integrations--post-partners

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/microservices/svc-partner-integrations/#integration-context ⬆ svc-partner-integrations Integration Context]]

title POST /partners\nRegister a new partner

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-partner-integrations" as Svc [[/microservices/svc-partner-integrations/]] #F3E8FF
database "PostgreSQL" as DB [[/microservices/svc-partner-integrations/#data-store]] #FEF9C3

note over Svc
  [[/services/api/svc-partner-integrations.html#/Partners/registerPartner View in Swagger UI]]
end note

Client -> GW : POST /partners
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FEF9C3
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml