@startuml svc-guide-management--get-guides-guide_id-ratings

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title GET /guides/{guide_id}/ratings\nGet guest ratings and reviews

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-guide-management" as Svc [[/microservices/svc-guide-management/]] #E8F4F8
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-guide-management.html#/Ratings/getGuideRatings View in Swagger UI]]
end note

Client -> GW : GET /guides/{guide_id}/ratings
activate GW #2563eb
GW -> Svc : [[/microservices/svc-guide-management/#get-guidesguide_idratings-get-guest-ratings-and-reviews route request]]
activate Svc #2563eb

== Database ==

Svc -> DB : SELECT ... WHERE parent_id = ?
activate DB #FCE4EC
DB --> Svc : ResultSet
deactivate DB

Svc --> GW : 200 OK
deactivate Svc
GW --> Client : 200 OK
deactivate GW

@enduml