@startuml svc-payments--post-payments

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title POST /payments\nProcess a payment

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-payments" as Svc [[/microservices/svc-payments/]] #E8F4F8
participant "Fraud Detection API" as FD #F5F5F5
participant "Stripe API" as ExtPay #F5F5F5
participant "Notifications" as Ntfy [[/microservices/svc-notifications/]] #FFF8F0
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-payments.html#/Payments/processPayment View in Swagger UI]]
end note

Client -> GW : POST /payments
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> FD : Screen transaction
activate FD #DBEAFE
FD --> Svc : OK
deactivate FD

Svc -> ExtPay : Process payment
activate ExtPay #DBEAFE
ExtPay --> Svc : OK
deactivate ExtPay

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

== Async Events ==

Svc ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send payment receipt]]

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml