@startuml svc-payments--post-payments

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title POST /payments\nProcess a payment

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-payments" as Svc [[/microservices/svc-payments/]] #E8F4F8
participant "Payment Gateway" as ExtPay #F5F5F5
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-payments.html#/Payments/processPayment View in Swagger UI]]
end note

Client -> GW : POST /payments
activate GW #059669
GW -> Svc : [[/microservices/svc-payments/#post-payments-process-a-payment route request]]
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> ExtPay : Process payment
activate ExtPay #DBEAFE
ExtPay --> Svc : OK
deactivate ExtPay

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml