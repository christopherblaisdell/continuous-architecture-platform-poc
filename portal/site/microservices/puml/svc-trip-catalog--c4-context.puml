@startuml
!include <c4/C4_Container>

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title svc-trip-catalog — Integration Context

Person(app_guest_mobile, "Adventure App", "Mobile App")
Person(web_guest_portal, "Guest Portal", "Web App")

System_Boundary(boundary, "NovaTrek Platform") {
    Container(svc_trip_catalog, "svc-trip-catalog", "Java / Spring Boot", "Trip Catalog Service")
    ContainerDb(svc_trip_catalog_db, "PostgreSQL 15", "catalog schema", "Primary data store")
    Container(svc_check_in, "svc-check-in", "Java / Spring Boot", "Operations")
    Container(svc_partner_integrations, "svc-partner-integrations", "Java / Spring Boot", "External")
    Container(svc_reservations, "svc-reservations", "Java / Spring Boot", "Booking")
    Container(svc_scheduling_orchestrator, "svc-scheduling-orchestrator", "Java / Spring Boot", "Operations")
}


Rel(app_guest_mobile, svc_trip_catalog, "Uses API", "HTTPS")
Rel(web_guest_portal, svc_trip_catalog, "Uses API", "HTTPS")
Rel(svc_check_in, svc_trip_catalog, "Get adventure category", "HTTPS")
Rel(svc_partner_integrations, svc_trip_catalog, "Check trip availability", "HTTPS")
Rel(svc_reservations, svc_trip_catalog, "2 calls", "HTTPS")
Rel(svc_scheduling_orchestrator, svc_trip_catalog, "2 calls", "HTTPS")
Rel(svc_trip_catalog, svc_trip_catalog_db, "Reads/Writes", "SQL/TCP")

@enduml