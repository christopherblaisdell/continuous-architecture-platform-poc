@startuml svc-safety-compliance--post-safety-inspections

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/microservices/svc-safety-compliance/#integration-context ⬆ svc-safety-compliance Integration Context]]

title POST /safety-inspections\nRecord a safety inspection

participant "Client" as Client [[/applications/]]
participant "API Gateway" as GW #DBEAFE
participant "svc-safety-compliance" as Svc [[/microservices/svc-safety-compliance/]] #E8F4F8
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-safety-compliance.html#/Inspections/createSafetyInspection View in Swagger UI]]
end note

Client -> GW : POST /safety-inspections
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml