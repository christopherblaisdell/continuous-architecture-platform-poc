@startuml svc-inventory-procurement--post-purchase-orders

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title POST /purchase-orders\nCreate a new purchase order

participant "Client" as Client
participant "API Gateway" as GW #DBEAFE
participant "svc-inventory-procurement" as Svc [[/microservices/svc-inventory-procurement/]] #E8F4F8
participant "Gear Inventory" as GI [[/microservices/svc-gear-inventory/]] #FFF8F0
database "PostgreSQL" as DB #FCE4EC

note over Svc
  [[/services/api/svc-inventory-procurement.html View in Swagger UI]]
end note

Client -> GW : POST /purchase-orders
activate GW #059669
GW -> Svc : route request
activate Svc #059669

note right of Svc : Validate request body

== Cross-Service Integration ==

Svc -> GI : [[/microservices/svc-gear-inventory/#get-gear-items-search-gear-inventory Verify item catalog]]
activate GI #DBEAFE
GI --> Svc : OK
deactivate GI

== Database ==

Svc -> DB : INSERT INTO ...
activate DB #FCE4EC
DB --> Svc : Created row
deactivate DB

Svc --> GW : 201 Created
deactivate Svc
GW --> Client : 201 Created
deactivate GW

@enduml