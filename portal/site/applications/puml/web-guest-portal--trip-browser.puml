@startuml web-guest-portal--trip-browser

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/applications/web-guest-portal/#service-dependencies ⬆ NovaTrek Guest Portal Service Dependencies]]

title Trip Browser\nNovaTrek Guest Portal

actor "Guest" as User [[/applications/web-guest-portal/]]
participant "Browser" as App [[/applications/web-guest-portal/]] #DBEAFE
participant "API Gateway" as GW #DBEAFE
participant "svc-trip-catalog" as TC [[/microservices/svc-trip-catalog/]] #E8F4F8
participant "svc-trail-management" as TM [[/microservices/svc-trail-management/]] #E8F4F8
participant "svc-weather" as WX [[/microservices/svc-weather/]] #E8F4F8
participant "svc-media-gallery" as MG [[/microservices/svc-media-gallery/]] #E8F4F8

User -> App : Open Trip Browser
activate App #2563eb
App -> GW : API request
activate GW #2563eb

== Backend Integration ==

GW -> TC : [[/microservices/svc-trip-catalog/#get-trips-search-trips-with-filters Search available trips]]
activate TC #DBEAFE
TC --> GW : OK
deactivate TC

GW -> TC : [[/microservices/svc-trip-catalog/#get-tripstrip_id-get-trip-details Get trip details]]
activate TC #DBEAFE
TC --> GW : OK
deactivate TC

GW -> TM : [[/microservices/svc-trail-management/#get-trailstrail_idconditions-get-current-trail-conditions Get trail conditions]]
activate TM #DBEAFE
TM --> GW : OK
deactivate TM

GW -> WX : [[/microservices/svc-weather/#get-weatherforecast-get-weather-forecast Get weather forecast]]
activate WX #DBEAFE
WX --> GW : OK
deactivate WX

GW -> MG : [[/microservices/svc-media-gallery/#get-media-list-media-by-reservation-or-trip Load trip photos]]
activate MG #DBEAFE
MG --> GW : OK
deactivate MG

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml