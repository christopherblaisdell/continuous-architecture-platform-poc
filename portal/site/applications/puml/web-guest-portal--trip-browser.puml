@startuml web-guest-portal--trip-browser

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/web-guest-portal/#service-dependencies ⬆ NovaTrek Guest Portal Service Dependencies]]

title Trip Browser\nNovaTrek Guest Portal

actor "Guest" as User [[/actors/#guest]]
participant "Browser" as App [[/applications/web-guest-portal/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-trip-catalog" as TC [[/microservices/svc-trip-catalog/]] #FEF3C7
participant "svc-trail-management" as TM [[/microservices/svc-trail-management/]] #FEF3C7
participant "svc-weather" as WX [[/microservices/svc-weather/]] #F1F5F9
participant "svc-media-gallery" as MG [[/microservices/svc-media-gallery/]] #F1F5F9

User -> App : Open Trip Browser
activate App #2563eb
App -> GW : API request
activate GW #2563eb

== Backend Integration ==

GW -> TC : [[/microservices/svc-trip-catalog/#get-trips-search-trips-with-filters Search available trips]]
activate TC #FEF3C7
TC --> GW : OK
deactivate TC

GW -> TC : [[/microservices/svc-trip-catalog/#get-tripstrip_id-get-trip-details Get trip details]]
activate TC #FEF3C7
TC --> GW : OK
deactivate TC

GW -> TM : [[/microservices/svc-trail-management/#get-trailstrail_idconditions-get-current-trail-conditions Get trail conditions]]
activate TM #FEF3C7
TM --> GW : OK
deactivate TM

GW -> WX : [[/microservices/svc-weather/#get-weatherforecast-get-weather-forecast Get weather forecast]]
activate WX #F1F5F9
WX --> GW : OK
deactivate WX

GW -> MG : [[/microservices/svc-media-gallery/#get-media-list-media-by-reservation-or-trip Load trip photos]]
activate MG #F1F5F9
MG --> GW : OK
deactivate MG

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml