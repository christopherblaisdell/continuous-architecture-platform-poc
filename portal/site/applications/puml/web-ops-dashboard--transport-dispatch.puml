@startuml web-ops-dashboard--transport-dispatch

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #dc2626
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title Transport Dispatch\nNovaTrek Operations Dashboard

actor "Guest" as User
participant "Browser" as App #DBEAFE
participant "API Gateway" as GW #DBEAFE
participant "svc-transport-logistics" as TL [[/microservices/svc-transport-logistics/]] #E8F4F8
participant "svc-location-services" as LS [[/microservices/svc-location-services/]] #E8F4F8
participant "svc-reservations" as Res [[/microservices/svc-reservations/]] #E8F4F8
participant "Google Maps Platform" as GM #F5F5F5

User -> App : Open Transport Dispatch
activate App #dc2626
App -> GW : API request
activate GW #dc2626

== Backend Integration ==

GW -> TL : [[/microservices/svc-transport-logistics/#get-transport-requestsrequest_id-get-transport-request-details List transport requests]]
activate TL #DBEAFE
TL --> GW : OK
deactivate TL

GW -> TL : [[/microservices/svc-transport-logistics/#post-transport-requests-request-transport-for-a-reservation Create transport request]]
activate TL #DBEAFE
TL --> GW : OK
deactivate TL

GW -> LS : [[/microservices/svc-location-services/#get-locationslocation_id-get-location-details Get pickup locations]]
activate LS #DBEAFE
LS --> GW : OK
deactivate LS

GW -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details Get booking details]]
activate Res #DBEAFE
Res --> GW : OK
deactivate Res

GW -> GM : Calculate optimal route
activate GM #DBEAFE
GM --> GW : OK
deactivate GM

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml