@startuml web-ops-dashboard--check-in-station

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #dc2626
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/web-ops-dashboard/#service-dependencies ⬆ NovaTrek Operations Dashboard Service Dependencies]]

title Check-In Station\nNovaTrek Operations Dashboard

actor "Guest" as User [[/actors/#guest]]
participant "Browser" as App [[/applications/web-ops-dashboard/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "svc-guest-profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE
participant "svc-safety-compliance" as SC [[/microservices/svc-safety-compliance/]] #FEE2E2
participant "svc-check-in" as CI [[/microservices/svc-check-in/]] #DBEAFE
participant "svc-gear-inventory" as GI [[/microservices/svc-gear-inventory/]] #CFFAFE

User -> App : Open Check-In Station
activate App #dc2626
App -> GW : API request
activate GW #dc2626

== Backend Integration ==

GW -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details Lookup reservation]]
activate Res #D1FAE5
Res --> GW : OK
deactivate Res

GW -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Verify guest identity]]
activate GP #EDE9FE
GP --> GW : OK
deactivate GP

GW -> SC : [[/microservices/svc-safety-compliance/#get-waivers-list-waivers-by-guest Check waiver status]]
activate SC #FEE2E2
SC --> GW : OK
deactivate SC

GW -> CI : [[/microservices/svc-check-in/#post-check-ins-initiate-check-in-for-a-participant Create check-in]]
activate CI #DBEAFE
CI --> GW : OK
deactivate CI

GW -> GI : [[/microservices/svc-gear-inventory/#post-gear-assignments-assign-gear-to-a-participant Assign gear package]]
activate GI #CFFAFE
GI --> GW : OK
deactivate GI

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml