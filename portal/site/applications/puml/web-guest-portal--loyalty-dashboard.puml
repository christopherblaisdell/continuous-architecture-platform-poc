@startuml web-guest-portal--loyalty-dashboard

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/web-guest-portal/#service-dependencies ⬆ NovaTrek Guest Portal Service Dependencies]]

title Loyalty Dashboard\nNovaTrek Guest Portal

actor "Guest" as User [[/actors/#guest]]
participant "Browser" as App [[/applications/web-guest-portal/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-loyalty-rewards" as LR [[/microservices/svc-loyalty-rewards/]] #F1F5F9
participant "svc-guest-profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE

User -> App : Open Loyalty Dashboard
activate App #2563eb
App -> GW : API request
activate GW #2563eb

== Backend Integration ==

GW -> LR : [[/microservices/svc-loyalty-rewards/#get-membersguest_idbalance-get-loyalty-member-balance-and-tier-info Get member balance]]
activate LR #F1F5F9
LR --> GW : OK
deactivate LR

GW -> LR : [[/microservices/svc-loyalty-rewards/#get-membersguest_idtransactions-list-point-transactions-for-a-member Get transaction history]]
activate LR #F1F5F9
LR --> GW : OK
deactivate LR

GW -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Get guest profile]]
activate GP #EDE9FE
GP --> GW : OK
deactivate GP

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml