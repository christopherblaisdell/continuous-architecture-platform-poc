@startuml app-guest-mobile--earn-loyalty-points

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/app-guest-mobile/#service-dependencies ⬆ NovaTrek Adventure App Service Dependencies]]

title Earn Loyalty Points\nNovaTrek Adventure App

actor "Guest" as User [[/actors/#guest]]
participant "Mobile App" as App [[/applications/app-guest-mobile/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-loyalty-rewards" as LR [[/microservices/svc-loyalty-rewards/]] #F1F5F9
participant "svc-reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "svc-guest-profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE

User -> App : Open Earn Loyalty Points
activate App #059669
App -> GW : API request
activate GW #059669

== Backend Integration ==

GW -> LR : [[/microservices/svc-loyalty-rewards/#get-membersguest_idbalance-get-loyalty-member-balance-and-tier-info Get member balance]]
activate LR #F1F5F9
LR --> GW : OK
deactivate LR

GW -> LR : [[/microservices/svc-loyalty-rewards/#post-membersguest_idearn-award-points-to-a-member Earn points]]
activate LR #F1F5F9
LR --> GW : OK
deactivate LR

GW -> Res : [[/microservices/svc-reservations/#get-reservations-search-reservations Get completed bookings]]
activate Res #D1FAE5
Res --> GW : OK
deactivate Res

GW -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Get guest profile]]
activate GP #EDE9FE
GP --> GW : OK
deactivate GP

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml