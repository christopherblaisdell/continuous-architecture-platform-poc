@startuml app-guest-mobile--earn-loyalty-points

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/applications/app-guest-mobile/#service-dependencies ⬆ NovaTrek Adventure App Service Dependencies]]

title Earn Loyalty Points\nNovaTrek Adventure App

actor "Guest" as User [[/applications/app-guest-mobile/]]
participant "Mobile App" as App [[/applications/app-guest-mobile/]] #DBEAFE
participant "API Gateway" as GW #DBEAFE
participant "svc-loyalty-rewards" as LR [[/microservices/svc-loyalty-rewards/]] #E8F4F8
participant "svc-reservations" as Res [[/microservices/svc-reservations/]] #E8F4F8
participant "svc-guest-profiles" as GP [[/microservices/svc-guest-profiles/]] #E8F4F8

User -> App : Open Earn Loyalty Points
activate App #059669
App -> GW : API request
activate GW #059669

== Backend Integration ==

GW -> LR : [[/microservices/svc-loyalty-rewards/#get-membersguest_idbalance-get-loyalty-member-balance-and-tier-info Get member balance]]
activate LR #DBEAFE
LR --> GW : OK
deactivate LR

GW -> LR : [[/microservices/svc-loyalty-rewards/#post-membersguest_idearn-award-points-to-a-member Earn points]]
activate LR #DBEAFE
LR --> GW : OK
deactivate LR

GW -> Res : [[/microservices/svc-reservations/#get-reservations-search-reservations Get completed bookings]]
activate Res #DBEAFE
Res --> GW : OK
deactivate Res

GW -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Get guest profile]]
activate GP #DBEAFE
GP --> GW : OK
deactivate GP

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml