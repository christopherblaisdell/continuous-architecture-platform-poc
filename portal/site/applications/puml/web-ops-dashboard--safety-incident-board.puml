@startuml web-ops-dashboard--safety-incident-board

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #dc2626
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/web-ops-dashboard/#service-dependencies ⬆ NovaTrek Operations Dashboard Service Dependencies]]

title Safety Incident Board\nNovaTrek Operations Dashboard

actor "Guest" as User [[/actors/#guest]]
participant "Browser" as App [[/applications/web-ops-dashboard/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-safety-compliance" as SC [[/microservices/svc-safety-compliance/]] #FEE2E2
participant "svc-guest-profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE
participant "svc-guide-management" as GM [[/microservices/svc-guide-management/]] #E0E7FF
participant "svc-notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9

User -> App : Open Safety Incident Board
activate App #dc2626
App -> GW : API request
activate GW #dc2626

== Backend Integration ==

GW -> SC : [[/microservices/svc-safety-compliance/#get-incidentsincident_id-get-an-incident-report List active incidents]]
activate SC #FEE2E2
SC --> GW : OK
deactivate SC

GW -> SC : [[/microservices/svc-safety-compliance/#post-incidents-file-an-incident-report Log new incident]]
activate SC #FEE2E2
SC --> GW : OK
deactivate SC

GW -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Get guest contact info]]
activate GP #EDE9FE
GP --> GW : OK
deactivate GP

GW -> GM : [[/microservices/svc-guide-management/#get-guidesguide_id-get-guide-by-id Get assigned guide]]
activate GM #E0E7FF
GM --> GW : OK
deactivate GM

GW ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send safety alerts]]
activate Ntfy #F1F5F9
Ntfy -->> GW : OK
deactivate Ntfy

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml