@startuml app-guest-mobile--weather-and-trail-alerts

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/app-guest-mobile/#service-dependencies ⬆ NovaTrek Adventure App Service Dependencies]]

title Weather and Trail Alerts\nNovaTrek Adventure App

actor "Guest" as User [[/actors/#guest]]
participant "Mobile App" as App [[/applications/app-guest-mobile/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-weather" as WX [[/microservices/svc-weather/]] #F1F5F9
participant "svc-trail-management" as TM [[/microservices/svc-trail-management/]] #FEF3C7
participant "OpenWeather API" as ExtWx #F3F4F6
participant "svc-notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9

User -> App : Open Weather and Trail Alerts
activate App #059669
App -> GW : API request
activate GW #059669

== Backend Integration ==

GW -> WX : [[/microservices/svc-weather/#get-weatheralerts-get-active-weather-alerts-for-a-region Get weather alerts]]
activate WX #F1F5F9
WX --> GW : OK
deactivate WX

GW -> TM : [[/microservices/svc-trail-management/#get-trailstrail_idconditions-get-current-trail-conditions Get trail closures]]
activate TM #FEF3C7
TM --> GW : OK
deactivate TM

GW -> ExtWx : Fetch severe alerts
activate ExtWx #F3F4F6
ExtWx --> GW : OK
deactivate ExtWx

GW ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Receive push notification]]
activate Ntfy #F1F5F9
Ntfy -->> GW : OK
deactivate Ntfy

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml