@startuml web-guest-portal--waiver-signing

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #2563eb
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/web-guest-portal/#service-dependencies ⬆ NovaTrek Guest Portal Service Dependencies]]

title Waiver Signing\nNovaTrek Guest Portal

actor "Guest" as User [[/actors/#guest]]
participant "Browser" as App [[/applications/web-guest-portal/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-safety-compliance" as SC [[/microservices/svc-safety-compliance/]] #FEE2E2
participant "svc-guest-profiles" as GP [[/microservices/svc-guest-profiles/]] #EDE9FE
participant "DocuSign API" as DS #F3F4F6
participant "svc-notifications" as Ntfy [[/microservices/svc-notifications/]] #F1F5F9

User -> App : Open Waiver Signing
activate App #2563eb
App -> GW : API request
activate GW #2563eb

== Backend Integration ==

GW -> SC : [[/microservices/svc-safety-compliance/#get-waivers-list-waivers-by-guest Get required waivers]]
activate SC #FEE2E2
SC --> GW : OK
deactivate SC

GW -> GP : [[/microservices/svc-guest-profiles/#get-guestsguest_id-get-guest-profile Get guest profile]]
activate GP #EDE9FE
GP --> GW : OK
deactivate GP

GW -> SC : [[/microservices/svc-safety-compliance/#post-waivers-guest-signs-a-safety-waiver Submit signed waiver]]
activate SC #FEE2E2
SC --> GW : OK
deactivate SC

GW -> DS : Verify digital signature
activate DS #F3F4F6
DS --> GW : OK
deactivate DS

GW ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send waiver copy]]
activate Ntfy #F1F5F9
Ntfy -->> GW : OK
deactivate Ntfy

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml