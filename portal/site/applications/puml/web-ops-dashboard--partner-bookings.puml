@startuml web-ops-dashboard--partner-bookings

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #dc2626
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/web-ops-dashboard/#service-dependencies ⬆ NovaTrek Operations Dashboard Service Dependencies]]

title Partner Bookings\nNovaTrek Operations Dashboard

actor "Guest" as User [[/actors/#guest]]
participant "Browser" as App [[/applications/web-ops-dashboard/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-partner-integrations" as PI [[/microservices/svc-partner-integrations/]] #F3E8FF
participant "svc-reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "svc-payments" as Pay [[/microservices/svc-payments/]] #F1F5F9

User -> App : Open Partner Bookings
activate App #dc2626
App -> GW : API request
activate GW #dc2626

== Backend Integration ==

GW -> PI : [[/microservices/svc-partner-integrations/#get-partner-bookingsbooking_id-get-partner-booking-details List partner bookings]]
activate PI #F3E8FF
PI --> GW : OK
deactivate PI

GW -> PI : [[/microservices/svc-partner-integrations/#post-partner-bookingsbooking_idconfirm-confirm-a-pending-partner-booking Confirm booking]]
activate PI #F3E8FF
PI --> GW : OK
deactivate PI

GW -> Res : [[/microservices/svc-reservations/#get-reservationsreservation_id-get-reservation-details Get reservation details]]
activate Res #D1FAE5
Res --> GW : OK
deactivate Res

GW -> Pay : [[/microservices/svc-payments/#get-paymentspayment_id-retrieve-payment-details Get payment status]]
activate Pay #F1F5F9
Pay --> GW : OK
deactivate Pay

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml