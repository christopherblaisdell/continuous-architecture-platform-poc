@startuml app-guest-mobile--photo-upload

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

header [[/applications/app-guest-mobile/#service-dependencies ⬆ NovaTrek Adventure App Service Dependencies]]

title Photo Upload\nNovaTrek Adventure App

actor "Guest" as User
participant "Mobile App" as App #DBEAFE
participant "API Gateway" as GW #DBEAFE
participant "svc-media-gallery" as MG [[/microservices/svc-media-gallery/]] #E8F4F8
participant "Object Store" as S3 #F5F5F5
participant "Google Maps Platform" as GM #F5F5F5
participant "svc-notifications" as Ntfy [[/microservices/svc-notifications/]] #E8F4F8

User -> App : Open Photo Upload
activate App #059669
App -> GW : API request
activate GW #059669

== Backend Integration ==

GW -> MG : [[/microservices/svc-media-gallery/#post-media-upload-a-media-item Upload photo]]
activate MG #DBEAFE
MG --> GW : OK
deactivate MG

GW -> S3 : Store binary file
activate S3 #DBEAFE
S3 --> GW : OK
deactivate S3

GW -> GM : Reverse geocode GPS
activate GM #DBEAFE
GM --> GW : OK
deactivate GM

GW -> MG : [[/microservices/svc-media-gallery/#post-mediamedia_idshare-create-a-shareable-link-for-a-media-item Create share link]]
activate MG #DBEAFE
MG --> GW : OK
deactivate MG

GW ->> Ntfy : [[/microservices/svc-notifications/#post-notifications-send-a-notification Send share notification]]
activate Ntfy #DBEAFE
Ntfy -->> GW : OK
deactivate Ntfy

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml