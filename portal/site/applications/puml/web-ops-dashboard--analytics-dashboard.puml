@startuml web-ops-dashboard--analytics-dashboard

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #dc2626
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #E8F4F8
    LifeLineBorderColor #A23B72
    BoxBorderColor #F18F01
    BoxBackgroundColor #FFF8F0
    NoteBorderColor #c77b30
    NoteBackgroundColor #FEF3E7
}

title Analytics Dashboard\nNovaTrek Operations Dashboard

actor "Guest" as User
participant "Browser" as App #DBEAFE
participant "API Gateway" as GW #DBEAFE
participant "svc-analytics" as AN [[/microservices/svc-analytics/]] #E8F4F8
participant "svc-reservations" as Res [[/microservices/svc-reservations/]] #E8F4F8
participant "svc-payments" as Pay [[/microservices/svc-payments/]] #E8F4F8
participant "Snowflake Data Cloud" as SF #F5F5F5

User -> App : Open Analytics Dashboard
activate App #dc2626
App -> GW : API request
activate GW #dc2626

== Backend Integration ==

GW -> AN : [[/microservices/svc-analytics/#get-analyticsbookings-get-booking-analytics-for-a-period Get booking metrics]]
activate AN #DBEAFE
AN --> GW : OK
deactivate AN

GW -> Res : [[/microservices/svc-reservations/#get-reservations-search-reservations Get reservation stats]]
activate Res #DBEAFE
Res --> GW : OK
deactivate Res

GW -> Pay : [[/microservices/svc-payments/#get-paymentsdaily-summary-get-daily-payment-summary Get revenue summary]]
activate Pay #DBEAFE
Pay --> GW : OK
deactivate Pay

GW -> SF : Query data warehouse
activate SF #DBEAFE
SF --> GW : OK
deactivate SF

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml