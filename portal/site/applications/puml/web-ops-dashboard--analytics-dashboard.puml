@startuml web-ops-dashboard--analytics-dashboard

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #dc2626
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/web-ops-dashboard/#service-dependencies ⬆ NovaTrek Operations Dashboard Service Dependencies]]

title Analytics Dashboard\nNovaTrek Operations Dashboard

actor "Guest" as User [[/actors/#guest]]
participant "Browser" as App [[/applications/web-ops-dashboard/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-analytics" as AN [[/microservices/svc-analytics/]] #F1F5F9
participant "svc-reservations" as Res [[/microservices/svc-reservations/]] #D1FAE5
participant "svc-payments" as Pay [[/microservices/svc-payments/]] #F1F5F9
participant "Snowflake Data Cloud" as SF #F3F4F6

User -> App : Open Analytics Dashboard
activate App #dc2626
App -> GW : API request
activate GW #dc2626

== Backend Integration ==

GW -> AN : [[/microservices/svc-analytics/#get-analyticsbookings-get-booking-analytics-for-a-period Get booking metrics]]
activate AN #F1F5F9
AN --> GW : OK
deactivate AN

GW -> Res : [[/microservices/svc-reservations/#get-reservations-search-reservations Get reservation stats]]
activate Res #D1FAE5
Res --> GW : OK
deactivate Res

GW -> Pay : [[/microservices/svc-payments/#get-paymentsdaily-summary-get-daily-payment-summary Get revenue summary]]
activate Pay #F1F5F9
Pay --> GW : OK
deactivate Pay

GW -> SF : Query data warehouse
activate SF #F3F4F6
SF --> GW : OK
deactivate SF

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml