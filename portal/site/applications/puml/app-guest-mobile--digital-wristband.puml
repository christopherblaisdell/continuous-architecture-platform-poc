@startuml app-guest-mobile--digital-wristband

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequence {
    ArrowColor #059669
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #F9FAFB
    LifeLineBorderColor #6B7280
    BoxBorderColor #94A3B8
    BoxBackgroundColor #F8FAFC
    NoteBorderColor #64748B
    NoteBackgroundColor #F8FAFC
}

header [[/applications/app-guest-mobile/#service-dependencies ⬆ NovaTrek Adventure App Service Dependencies]]

title Digital Wristband\nNovaTrek Adventure App

actor "Guest" as User [[/actors/#guest]]
participant "Mobile App" as App [[/applications/app-guest-mobile/]] #E0F2FE
participant "API Gateway" as GW [[/actors/#api-gateway]] #E0F2FE
participant "svc-check-in" as CI [[/microservices/svc-check-in/]] #DBEAFE
participant "svc-gear-inventory" as GI [[/microservices/svc-gear-inventory/]] #CFFAFE

User -> App : Open Digital Wristband
activate App #059669
App -> GW : API request
activate GW #059669

== Backend Integration ==

GW -> CI : [[/microservices/svc-check-in/#get-check-inscheck_in_id-get-check-in-details Get check-in status]]
activate CI #DBEAFE
CI --> GW : OK
deactivate CI

GW -> GI : [[/microservices/svc-gear-inventory/#get-gear-assignmentsassignment_id-get-gear-assignment-details Verify gear assignment]]
activate GI #CFFAFE
GI --> GW : OK
deactivate GI

GW --> App : Response
deactivate GW
App --> User : Render screen
deactivate App

@enduml